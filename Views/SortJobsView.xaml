<UserControl x:Class="Traker.Views.SortJobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:local="clr-namespace:Traker.Views"
             xmlns:cal="http://caliburnmicro.com"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Width="295" VerticalAlignment="Center" Background="#2A2A2F" CornerRadius="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="2"/>
        </Border.Effect>
        <Grid VerticalAlignment="Center">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />                    <!-- order -->
                    <RowDefinition Height="auto" />                    <!-- spacer -->
                    <RowDefinition Height="auto" />                    <!-- options -->
                </Grid.RowDefinitions>

                <!-- order -->
                <Grid Grid.Row="0">
                    <Border Background="#1E1E1E" CornerRadius="15" BorderThickness="0,1,0,0" Margin="0,0,0,10">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.12">
                                <GradientStop Color="#26FFFFFF" Offset="0" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid Margin="10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />                                <!-- ascending -->
                                <ColumnDefinition Width="*" />                                <!-- descending -->
                            </Grid.ColumnDefinitions>

                            <!-- ascending -->
                            <Grid Grid.Column="0">
                                <Border Cursor="Hand" Opacity="{Binding OpacityOrderStyle[0]}" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action OrderStyle(0)]" Background="#3F3F46" CornerRadius="17" Height="35" Margin="0,0,5,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="8" Direction="270"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,3,0,0">
                                        <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/arrow-down-narrow-wide.svg" Width="15" Height="15"/>
                                        <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Text="Ascending" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- descending -->
                            <Grid Grid.Column="1">
                                <Border Cursor="Hand" Opacity="{Binding OpacityOrderStyle[1]}" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action OrderStyle(1)]" Background="#3F3F46" CornerRadius="17" Height="35" Margin="5,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="8" Direction="270"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,3,0,0">
                                        <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/arrow-down-wide-narrow.svg" Width="15" Height="15"/>
                                        <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Text="Descending" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- spacer -->
                <Grid Grid.Row="1" Margin="0,0,0,0" />

                <!-- options -->
                <Grid Grid.Row="2">
                    <Border Background="#1E1E1E" CornerRadius="15" BorderThickness="1" Height="150" VerticalAlignment="Center">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.12">
                                <GradientStop Color="#26FFFFFF" Offset="0" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250">
                                <!-- client name -->
                                <Grid Height="50">
                                    <Border Cursor="Hand" Opacity="{Binding OpacityOptions[0]}" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SortOption(0)]" Background="#3F3F46" CornerRadius="17" Height="35">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="8" Direction="270"/>
                                        </Border.Effect>
                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Client Name" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                                    </Border>
                                </Grid>

                                <!-- job name -->
                                <Grid Height="50">
                                    <Border Cursor="Hand" Opacity="{Binding OpacityOptions[1]}" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SortOption(1)]" Background="#3F3F46" CornerRadius="17" Height="35">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="8" Direction="270"/>
                                        </Border.Effect>
                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Job Name" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                                    </Border>
                                </Grid>

                                <!-- job status -->
                                <Grid Height="50">
                                    <Border Cursor="Hand" Opacity="{Binding OpacityOptions[2]}" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SortOption(2)]" Background="#3F3F46" CornerRadius="17" Height="35">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="8" Direction="270"/>
                                        </Border.Effect>
                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Job Status" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                                    </Border>
                                </Grid>

                                <!-- job Price -->
                                <Grid Height="50">
                                    <Border Cursor="Hand" Opacity="{Binding OpacityOptions[3]}" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SortOption(3)]" Background="#3F3F46" CornerRadius="17" Height="35">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="8" Direction="270"/>
                                        </Border.Effect>
                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Job Price" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                                    </Border>
                                </Grid>

                                <!-- Due Date -->
                                <Grid Height="50">
                                    <Border Cursor="Hand" Opacity="{Binding OpacityOptions[4]}" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SortOption(4)]" Background="#3F3F46" CornerRadius="17" Height="35">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="8" Direction="270"/>
                                        </Border.Effect>
                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Due Date" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                                    </Border>
                                </Grid>

                                <!-- created Date -->
                                <Grid Height="50">
                                    <Border Cursor="Hand" Opacity="{Binding OpacityOptions[5]}" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SortOption(5)]" Background="#3F3F46" CornerRadius="17" Height="35">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="8" Direction="270"/>
                                        </Border.Effect>
                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Created Date" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                                    </Border>
                                </Grid>

                                <!-- business type -->
                                <Grid Height="50">
                                    <Border Cursor="Hand" Opacity="{Binding OpacityOptions[6]}" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SortOption(6)]" Background="#3F3F46" CornerRadius="17" Height="35">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="8" Direction="270"/>
                                        </Border.Effect>
                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Business Type" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>