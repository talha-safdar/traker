<UserControl x:Class="Traker.Views.JobsListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Traker.Views"
             xmlns:cal="http://caliburnmicro.com" 
             xmlns:conv="clr-namespace:Traker.Converters"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Height="800" Width="1000">
    <Border Background="#1E1E1E" CornerRadius="20" BorderThickness="1" SnapsToDevicePixels="True">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                <GradientStop Color="LightGray" Offset="0" />
                <GradientStop Color="Transparent" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Grid Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.05*" />                <!-- top bar        -->
                <RowDefinition Height="*" />                <!-- main contents       -->
            </Grid.RowDefinitions>

            <!-- top bar -->
            <Grid Grid.Row="0">
                <Border Cursor="Hand" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action Exit()]" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="20" Height="35" Width="35">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#404040"/>
                            <Setter Property="Opacity" Value="0.5"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <svg:SvgViewbox                         
                    RenderOptions.BitmapScalingMode="HighQuality"
                    SnapsToDevicePixels="True"
                    Source="/Resources/Media/Images/Icons/Lucide/x.svg" Width="15" Height="15"/>
                </Border>
            </Grid>

            <!-- main contents -->
            <Grid Grid.Row="1" VerticalAlignment="Center" Margin="30,0,30,0" Height="600">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" /> <!-- client name -->
                    <RowDefinition Height="0.03*" /> <!-- spacer -->
                    <RowDefinition Height="*" /> <!-- list-->
                </Grid.RowDefinitions>

                <!-- client name -->
                <Grid Grid.Row="0">
                    <Border Background="#242424" CornerRadius="15" SnapsToDevicePixels="True" HorizontalAlignment="Center" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                <!-- This whole gradient is now at 50% of its original opacity -->
                                <GradientStop Color="LightGray" Offset="0" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel Margin="10" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Opacity="0.5" Background="#444444"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="40" Width="40">
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="{Binding ClientType}" Width="20" Height="20"/>
                            </Border>
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,0,0" Text="{Binding BusinessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="34" />
                        </StackPanel>                        
                    </Border>
                </Grid>

                <Grid Grid.Row="1" />

                <!-- list-->
                <Border Grid.Row="2" Background="#242424" CornerRadius="15" SnapsToDevicePixels="True" BorderThickness="1.5" >
                    <Border.BorderBrush>
                        <SolidColorBrush Color="LightGray" Opacity="0.15" />
                    </Border.BorderBrush>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="500" Margin="10,20,10,10" Padding="0,0,10,0">
                        <ItemsControl ItemsSource="{Binding JobsList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border 
                                        Background="#242424"
                            BorderThickness="1"
                            Height="135"
                            CornerRadius="20" 
                            Margin="20,10,20,10" 
                            Padding="10"
                            cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SelectJob($dataContext)];
                                                [Event MouseRightButtonUp] = [Action OpenContextMenu($dataContext)];"
                                Cursor="Hand"
                            MouseLeftButtonDown="EditJob">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <!-- 1. Default BorderBrush -->
                                                <Setter Property="BorderBrush" Value="#121212"/>

                                                <!-- 2. Default Shadow (Moved from local to Style) -->
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="Black" 
                                                          BlurRadius="15" 
                                                          ShadowDepth="0" 
                                                          Opacity="0.3" 
                                                          RenderingBias="Quality"/>
                                                    </Setter.Value>
                                                </Setter>

                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#80404040"/>

                                                        <!-- 3. Increased Blur Shadow on Hover -->
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="Black" 
                                                                  BlurRadius="30" 
                                                                  ShadowDepth="0" 
                                                                  Opacity="0.8" 
                                                                  RenderingBias="Quality"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>



                                        <Grid IsHitTestVisible="False">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />                                                <!-- job title -->
                                                <ColumnDefinition Width="0.2*" />                                                <!-- spacer -->
                                                <ColumnDefinition Width="*" />                                                <!-- job status / due date -->
                                                <ColumnDefinition Width="0.2*" />                                                <!-- spacer -->
                                                <ColumnDefinition Width="*" />                                                <!-- job price -->
                                            </Grid.ColumnDefinitions>

                                            <!-- full name / job title -->
                                            <Grid Margin="30,0,0,0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" /> <!-- title -->
                                                    <RowDefinition Height="0.5*" />                                                    <!-- spacer -->
                                                    <RowDefinition Height="*" /> <!-- job title-->
                                                </Grid.RowDefinitions>
                                                
                                                <!-- title -->
                                                <Grid Grid.Row="0">
                                                    <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Text="Job Title" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="#888888" FontSize="24" />
                                                </Grid>

                                                <!-- spacer -->
                                                <Grid Grid.Row="1" Margin="0,2" />

                                                <!-- job title -->
                                                <Grid Grid.Row="2">
                                                    <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Text="{Binding JobTitle}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="24" />                                                    
                                                </Grid>
                                            </Grid>

                                            <!-- spacer-->
                                            <Grid Grid.Column="1">
                                                <!--<Border Margin="0,0" Width="1" SnapsToDevicePixels="True" Opacity="0.6">
                                                    <Border.Background>
                                                        --><!-- Changed StartPoint/EndPoint to move vertically (Top to Bottom) --><!--
                                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="1">
                                                            --><!-- Top: Transparent --><!--
                                                            <GradientStop Color="#00555555" Offset="0" />
                                                            --><!-- Middle: Your #555555 color --><!--
                                                            <GradientStop Color="#FF555555" Offset="0.2" />
                                                            <GradientStop Color="#FF555555" Offset="0.8" />
                                                            --><!-- Bottom: Transparent --><!--
                                                            <GradientStop Color="#00555555" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>-->
                                            </Grid>

                                            <!-- job status / due date -->
                                            <Grid Grid.Column="2" HorizontalAlignment="Center">
                                                <Grid Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*" />                                                        <!-- job status -->
                                                        <RowDefinition Height="0.5*" />                                                        <!-- spacer -->
                                                        <RowDefinition Height="*" />                                                        <!-- due date -->
                                                    </Grid.RowDefinitions>

                                                    <!-- job status -->
                                                    <Grid Grid.Row="0">
                                                        <TextBlock Margin="0" Text="{Binding JobStatus}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Black" FontSize="32">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource FontPrimaryBrush}" />

                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding JobStatus}" Value="New">
                                                                            <Setter Property="Foreground" Value="LightCoral" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding JobStatus}" Value="Active">
                                                                            <Setter Property="Foreground" Value="DarkOrange" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding JobStatus}" Value="Done">
                                                                            <Setter Property="Foreground" Value="LightGreen" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding JobStatus}" Value="Invoiced">
                                                                            <Setter Property="Foreground" Value="LightBlue" />
                                                                            <Setter Property="FontWeight" Value="Bold" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>

                                                    <!-- spacer -->
                                                    <Grid Grid.Row="1" Margin="0,10" />

                                                    <!-- due date -->
                                                    <Grid Grid.Row="2">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock HorizontalAlignment="Left" Margin="0" Text="Due" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="24" />
                                                            <TextBlock Margin="10,0,0,0" Text="{Binding DueDate}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="24" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Grid>

                                            <!-- spacer -->
                                            <Grid Grid.Column="3">
                                                <!--<Border Margin="0,0" Width="1" SnapsToDevicePixels="True" Opacity="0.6">
                                                    <Border.Background>
                                                        --><!-- Changed StartPoint/EndPoint to move vertically (Top to Bottom) --><!--
                                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="1">
                                                            --><!-- Top: Transparent --><!--
                                                            <GradientStop Color="#00555555" Offset="0" />
                                                            --><!-- Middle: Your #555555 color --><!--
                                                            <GradientStop Color="#FF555555" Offset="0.2" />
                                                            <GradientStop Color="#FF555555" Offset="0.8" />
                                                            --><!-- Bottom: Transparent --><!--
                                                            <GradientStop Color="#00555555" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>-->
                                            </Grid>

                                            <!-- job price -->
                                            <Grid Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Margin="0" Text="{Binding Price}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="SemiBold" Foreground="{StaticResource FontPrimaryBrush}" FontSize="32" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>