<UserControl x:Class="Traker.Views.Edit.EditJobView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:cal="http://caliburnmicro.com"
             xmlns:local="clr-namespace:Traker.Views" xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:conv="clr-namespace:Traker.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Height="800" Width="1000">
    <Border Background="#1E1E1E" CornerRadius="20" BorderThickness="1" SnapsToDevicePixels="True">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                <GradientStop Color="LightGray" Offset="0" />
                <GradientStop Color="Transparent" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Grid Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.1*" />                <!-- top bar        -->
                <RowDefinition Height="*" />                <!-- main contents       -->
                <RowDefinition Height="0.15*" />                <!-- buttons        -->
            </Grid.RowDefinitions>

            <!-- top bar -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>                    <!-- button -->
                    <ColumnDefinition Width="0.1*"/>                    <!-- close -->
                </Grid.ColumnDefinitions>

                <!-- button -->
                <Grid Grid.Column="0">
                    <TextBlock VerticalAlignment="Center" Margin="5,0,10,0" Text="{Binding ClientName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="SemiBold" Foreground="{StaticResource FontPrimaryBrush}" FontSize="34" />
                </Grid>

                <!-- close -->
                <Grid Grid.Column="1">
                    <Border Cursor="Hand" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action Exit()]" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="20" Height="35" Width="35">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#404040"/>
                                <Setter Property="Opacity" Value="0.5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <svg:SvgViewbox                         
                        RenderOptions.BitmapScalingMode="HighQuality"
                        SnapsToDevicePixels="True"
                        Source="/Resources/Media/Images/Icons/Lucide/x.svg" Width="15" Height="15"/>
                    </Border>
                </Grid>
            </Grid>

            <!-- main contents -->
            <Grid Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />                        <!-- job title / description -->
                        <ColumnDefinition Width="*" />                        <!-- job info -->
                    </Grid.ColumnDefinitions>

                    <!-- title / status -->
                    <Grid Grid.Column="0">
                        <Border Background="#242424" CornerRadius="15" BorderThickness="1.5" Margin="40,40,20,40" SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="LightGray" Opacity="0.25" />
                            </Border.BorderBrush>

                            <Grid Margin="30">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />                                    <!-- job title -->
                                    <RowDefinition Height="auto" />                                    <!-- job description-->
                                </Grid.RowDefinitions>

                                <!-- job title -->
                                <Grid Grid.Row="0">
                                    <StackPanel Orientation="Vertical" Margin="0,0,0,25">
                                        <TextBlock Margin="5,0,0,5" Text="Job Title" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                        <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding JobTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

                                <!-- job description -->
                                <Grid Grid.Row="1">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="5,0,0,5" Text="Job Description" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                        <TextBox Style="{DynamicResource TextBoxNormal}" HorizontalAlignment="Left" Text="{Binding JobDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="10" MaxLength="1000" Height="310" Width="345" AcceptsReturn="False" FontSize="22"  FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- job info -->
                    <Grid Grid.Column="1">
                        <Border Background="#242424" CornerRadius="15" BorderThickness="1.5" Margin="20,40,40,40" SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="LightGray" Opacity="0.25" />
                            </Border.BorderBrush>

                            <Grid Margin="30">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />                                    <!-- stauts -->
                                    <RowDefinition Height="*" />                                    <!-- price -->
                                    <RowDefinition Height="*" />                                    <!-- received -->
                                    <RowDefinition Height="0.7*" />                                    <!-- remaining -->
                                    <RowDefinition Height="*" />                                    <!-- dates -->
                                </Grid.RowDefinitions>

                                <!-- stauts -->
                                <Grid Grid.Row="0">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock VerticalAlignment="Center" Margin="5,0,0,5" Text="Status" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22" />
                                        <ComboBox Style="{DynamicResource ComboBoxNormal}" SelectedValue="{Binding Status, Mode=TwoWay}" SelectedValuePath="Content" FontSize="22">
                                            <ComboBoxItem Content="New" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                            <ComboBoxItem Content="Active" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                            <ComboBoxItem Content="Done" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!-- price -->
                                <Grid Grid.Row="1">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="5,0,0,5" Text="Price" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                        <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

                                <!-- received -->
                                <Grid Grid.Row="2">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="5,0,0,5" Text="Received" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                        <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding AmountReceived, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

                                <!-- remeaning -->
                                <Grid Grid.Row="3">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="5,0,0,0" FontFamily="pack://Traker:,,,/Resources/Fonts/#Roboto Mono" FontWeight="Regular" Foreground="#888888" FontSize="22">
                                            <Run Text="Remeaning: " />
                                            <Run Text="{Binding ReaminingAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Roboto Mono" FontWeight="SemiBold" FontSize="26" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>

                                <!-- dates -->
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />                                        <!-- start -->
                                        <ColumnDefinition Width="*" />                                        <!-- due -->
                                    </Grid.ColumnDefinitions>

                                    <!-- start -->
                                    <Grid Grid.Column="0">
                                        <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                                            <TextBlock Margin="5,0,0,5" Text="Start Date" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                            <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding AmountReceived, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- due -->
                                    <Grid Grid.Column="1">
                                        <StackPanel Orientation="Vertical" Margin="10,0,0,0">
                                            <TextBlock Margin="5,0,0,5" Text="End Date" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                            <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding AmountReceived, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- butons -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />                        <!-- delete client -->
                    <ColumnDefinition Width="*" />                        <!-- spacer -->
                    <ColumnDefinition Width="auto" />                        <!-- save -->
                </Grid.ColumnDefinitions>

                <!-- delete job -->
                <Grid Grid.Column="0" Margin="40,0,0,0">
                    <TextBlock Cursor="Hand" conv:TextBlockSpacer.LetterSpacing="2.01" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Delete Job" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" Foreground="#B04141" FontWeight="Regular" FontSize="16" />
                </Grid>

                <!-- save -->
                <Grid Grid.Column="2" Margin="0,0,40,0">
                    <Border Cursor="Hand" SnapsToDevicePixels="True" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action ConfirmJobChanges()]" Background="#333333" CornerRadius="25" Height="45" Width="200" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <!-- DEFAULT STATE -->
                                <Setter Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                            <GradientStop Color="LightGray" Offset="0" />
                                            <GradientStop Color="Transparent" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>

                                <!-- HOVER STATE -->
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock conv:TextBlockSpacer.LetterSpacing="2.01" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Save Changes" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="18" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>