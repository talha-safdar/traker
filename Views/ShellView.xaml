<Window x:Class="Traker.Views.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:conv="clr-namespace:Traker.Converters"
        xmlns:cal="http://caliburnmicro.com"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:lottie="clr-namespace:LottieSharp.WPF;assembly=LottieSharp"
        mc:Ignorable="d"
    WindowState="Maximized"
    Title="Traker" 
    MinHeight="600" MinWidth="1200"

WindowStyle="None"
    ResizeMode="CanResize"
    AllowsTransparency="False"
    Background="#01000000"
    StateChanged="Window_StateChanged">

    <Window.Resources>
        <conv:BoolToVisibilityCollapsed x:Key="BoolToVisCollapsed"/>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="32"
            ResizeBorderThickness="8"
            CornerRadius="20"
            GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource MainBackgroundBrush}" cal:Message.Attach="[Event PreviewMouseDown] = [Action OnMouseDownEvent($source)]">       
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.07*"/> <!-- top bar-->
                <RowDefinition Height="*"/> <!-- body -->
            </Grid.RowDefinitions>

            <!-- top bar -->
            <Grid Grid.Row="0" Background="#242424" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /> <!-- app name -->
                        <ColumnDefinition Width="auto" /> <!-- minimise, close, drag -->
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Border Background="Transparent" MouseLeftButtonDown="DragWindow">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock conv:TextBlockSpacer.LetterSpacing="2.20" Text="TRAKER " FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="ExtraBlack" Foreground="{StaticResource FontPrimaryBrush}" FontSize="26" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
                                <TextBlock Text="for Employers" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Border Cursor="Hand" SnapsToDevicePixels="True" Margin="0, 0, 20, 0" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action Minimise()]" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="0.9" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Image Width="25" Source="/Resources/Media/Images/Icons/minimise-button.png" Opacity="0.9" />
                            </Border>
                            <Border Cursor="Hand" SnapsToDevicePixels="True" Margin="0, 0, 0, 0" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action Exit()]" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="0.9" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Image Width="25" Source="/Resources/Media/Images/Icons/close-button.png" Opacity="0.9" />
                            </Border>
                        </StackPanel>
                    </Grid>      
                </Grid>
            </Grid>

            <!-- body -->
            <Grid Grid.Row="1">
                <ContentControl x:Name="ActiveItem" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
            </Grid>
            
            <!-- loading -->
            <Grid Grid.RowSpan="2" x:Name="OverlayGrid" Background="Transparent" Visibility="{Binding State.IsBusy, Converter={StaticResource BoolToVisCollapsed}}">
                <Border Background="Black" Opacity="0.5" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- loading animation -->
                            <RowDefinition Height="auto" />
                            <!-- text -->
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <!-- loading animation -->
                        <Grid Grid.Row="0">
                            <Border Width="150" Height="200" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="1"
                                      Color="#2D2D34"/>
                                </Border.Effect>
                                <lottie:LottieAnimationView 
                                    x:Name="Loader"
                                    AutoPlay="True"                                            
                                    RepeatCount="-1" />
                            </Border>
                        </Grid>

                        <!-- text -->
                        <Grid Grid.Row="1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding State.LoadingMessage}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" conv:TextBlockSpacer.LetterSpacing="5.0" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="24" />
                                <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                                    <TextBlock x:Name="Dot1" Text="." FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" conv:TextBlockSpacer.LetterSpacing="5.0" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="22" />
                                    <TextBlock x:Name="Dot2" Text="." FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" conv:TextBlockSpacer.LetterSpacing="5.0" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="22" />
                                    <TextBlock x:Name="Dot3" Text="." FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" conv:TextBlockSpacer.LetterSpacing="5.0" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="22" />
                                </StackPanel>

                                <StackPanel.Triggers>
                                    <EventTrigger RoutedEvent="StackPanel.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">

                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity">
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:1" Value="1.0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.5" Value="0.0"/>
                                                </DoubleAnimationUsingKeyFrames>

                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity">
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2" Value="1.0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.5" Value="0.0"/>
                                                </DoubleAnimationUsingKeyFrames>

                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity">
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3" Value="1.0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.5" Value="0.0"/>
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </StackPanel.Triggers>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </StackPanel>                
            </Grid>
        </Grid>
    </Border>
</Window>
