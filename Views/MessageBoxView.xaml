<UserControl x:Class="Traker.Views.MessageBoxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:local="clr-namespace:Traker.Views"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:names="clr-namespace:Traker.Helper"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Width="400" Height="250">

    <Border Visibility="{Binding IsVisible}" Background="#1A1A1A" CornerRadius="20" BorderThickness="1" SnapsToDevicePixels="True" Margin="5">
        <Border.Effect>
            <DropShadowEffect
            BlurRadius="10"
            ShadowDepth="0"
            Color="Black"
            Opacity="0.5"
            RenderingBias="Quality"/>
        </Border.Effect>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                <GradientStop Color="LightGray" Offset="0" />
                <GradientStop Color="Transparent" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.3*" /> <!-- header -->
                <RowDefinition Height="0.1*" /> <!-- spacer -->
                <RowDefinition Height="*" /> <!-- main body -->
                <RowDefinition Height="0.1*" /> <!-- spacer -->
                <RowDefinition Height="0.4*" /> <!-- buttons -->
            </Grid.RowDefinitions>
            
            <!-- header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.1*" />                    <!-- symbol -->
                    <ColumnDefinition Width="*" />                    <!-- message -->
                </Grid.ColumnDefinitions>

                <!-- symbol -->
                <Grid Grid.Column="0">
                    <svg:SvgViewbox RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Width="25" Height="25">
                        <svg:SvgViewbox.Style>
                            <Style TargetType="svg:SvgViewbox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Symbol}" Value="0">
                                        <Setter Property="Source" Value="/Resources/Media/Images/Icons/Lucide/MessageBox/info.svg"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect
                                                    BlurRadius="30"
                                                    ShadowDepth="0"
                                                    Color="#88B0D0"
                                                    Opacity="0.20"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Symbol}" Value="1">
                                        <Setter Property="Source" Value="/Resources/Media/Images/Icons/Lucide/MessageBox/triangle-alert.svg"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect
                                                    BlurRadius="30"
                                                    ShadowDepth="0"
                                                    Color="#E8C08D"
                                                    Opacity="0.20"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Symbol}" Value="2">
                                        <Setter Property="Source" Value="/Resources/Media/Images/Icons/Lucide/MessageBox/circle-x.svg"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect
                                                    BlurRadius="30"
                                                    ShadowDepth="0"
                                                    Color="#D68A8A"
                                                    Opacity="0.20"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </svg:SvgViewbox.Style>
                    </svg:SvgViewbox>
                </Grid>
                
                <!-- message -->
                <Grid Grid.Column="1">
                    <TextBlock VerticalAlignment="Center" Margin="5,0,0,0" Text="{Binding HeadMessage}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="#F8FBFD" FontSize="22" Opacity="0.8" />
                </Grid>                
            </Grid>

            <!-- spacer -->
            <Grid Grid.Row="1" />
            
            <!-- main body -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.025*" />                <!-- symbol -->
                    <ColumnDefinition Width="*" />                <!-- message -->
                </Grid.ColumnDefinitions>

                <!-- line colour -->
                <Grid Grid.Column="0">
                    <Border Width="1" Opacity="0.8" CornerRadius="3" Margin="0,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Symbol}" Value="0">
                                        <Setter Property="Background" Value="#88B0D0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Symbol}" Value="1">
                                        <Setter Property="Background" Value="#E8C08D"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Symbol}" Value="2">
                                        <Setter Property="Background" Value="#D68A8A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>

                <!-- message -->
                <Grid Grid.Column="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Width="350">
                        <TextBlock TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" Text="{Binding Message}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="Medium" Foreground="#A0A0A0" FontSize="16" />
                    </ScrollViewer>            
                </Grid>
            </Grid>

            <!-- spacer -->
            <Grid Grid.Row="3" />

            <!-- buttons -->
            <Grid Grid.Row="4">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- LEFT -->
                    <Border Margin="0,0,5,0" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action LeftButton()]" x:Name="LeftBorder" MouseLeave="LeftBorder_MouseLeave" MouseLeftButtonUp="LeftBorder_MouseLeftButtonUp" MouseLeftButtonDown="LeftBorder_MouseLeftButtonDown" SnapsToDevicePixels="True" BorderThickness="1" Background="Transparent" VerticalAlignment="Center" CornerRadius="10" Height="40" Width="175">
                        <Border.Style>
                            <Style TargetType="Border">
                                <!-- 1. Base Background (rgba 255,255,255, 0.05) -->
                                <Setter Property="Background" Value="#0DFFFFFF" />
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <!-- 2. The 1px Gradient Border -->
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <!-- Top Highlight -->
                                            <GradientStop Color="#40FFFFFF" Offset="0" />
                                            <!-- Bottom Fade -->
                                            <GradientStop Color="#05FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ButtonStyle}" Value="{x:Static names:Names.OK}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ButtonStyle}" Value="{x:Static names:Names.CancelOK}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ButtonStyle}" Value="{x:Static names:Names.NoYes}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>

                                    <!-- 3. Hover State -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <!-- Increase opacity to rgba 255,255,255, 0.1 -->
                                        <Setter Property="Background" Value="#1AFFFFFF" />
                                        <Setter Property="Cursor" Value="Hand" />

                                        <!-- 4. Subtle Glow -->
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="10" 
                                                    Color="LightGray" 
                                                    Opacity="0.15" 
                                                    ShadowDepth="0" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Medium" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#888888"/>
                                    <Setter Property="Text" Value=""/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=LeftBorder}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>

                                        <!-- 0=Left button not shown -->
                                        <DataTrigger Binding="{Binding ButtonStyle}" Value="{x:Static names:Names.OK}">
                                            <Setter Property="Text" Value=""/>
                                        </DataTrigger>
                                        
                                        <!-- 1=Cancel -->
                                        <DataTrigger Binding="{Binding ButtonStyle}" Value="{x:Static names:Names.CancelOK}">
                                            <Setter Property="Text" Value="Cancel"/>
                                        </DataTrigger>
                                        
                                        <!-- 2=No -->
                                        <DataTrigger Binding="{Binding ButtonStyle}" Value="{x:Static names:Names.NoYes}">
                                            <Setter Property="Text" Value="No"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    
                    <!-- RIGHT -->
                    <Border Margin="5,0,0,0" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action RightButton()]" x:Name="RightBorder" MouseLeave="RightBorder_MouseLeave" MouseLeftButtonUp="RightBorder_MouseLeftButtonUp" MouseLeftButtonDown="RightBorder_MouseLeftButtonDown" SnapsToDevicePixels="True" BorderThickness="1" Background="#1E1E1E" VerticalAlignment="Center" CornerRadius="10" Height="40" Width="175">
                        <Border.Style>
                            <Style TargetType="Border">
                                <!-- 1. Base Background (rgba 255,255,255, 0.05) -->
                                <Setter Property="Background" Value="#0DFFFFFF" />

                                <!-- 2. The 1px Gradient Border -->
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <!-- Top Highlight -->
                                            <GradientStop Color="#40FFFFFF" Offset="0" />
                                            <!-- Bottom Fade -->
                                            <GradientStop Color="#05FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <!-- 3. Hover State -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <!-- Increase opacity to rgba 255,255,255, 0.1 -->
                                        <Setter Property="Background" Value="#1AFFFFFF" />
                                        <Setter Property="Cursor" Value="Hand" />

                                        <!-- 4. Subtle Glow -->
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="10" 
                                                    Color="LightGray" 
                                                    Opacity="0.15" 
                                                    ShadowDepth="0" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Medium" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#888888"/>
                                    <Setter Property="Text" Value=""/>
                                    <Style.Triggers>                                        
                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=RightBorder}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        
                                        <!-- 0=OK -->
                                        <DataTrigger Binding="{Binding ButtonStyle}" Value="{x:Static names:Names.OK}">
                                            <Setter Property="Text" Value="Ok"/>
                                        </DataTrigger>
                                        
                                        <!-- 1=OK -->
                                        <DataTrigger Binding="{Binding ButtonStyle}" Value="{x:Static names:Names.CancelOK}">
                                            <Setter Property="Text" Value="Ok"/>
                                        </DataTrigger>
                                        
                                        <!-- 1=Yes -->
                                        <DataTrigger Binding="{Binding ButtonStyle}" Value="{x:Static names:Names.NoYes}">
                                            <Setter Property="Text" Value="Yes"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
