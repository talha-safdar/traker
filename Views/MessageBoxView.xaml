<UserControl x:Class="Traker.Views.MessageBoxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Traker.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Width="400" Height="250">
             
    <Border Background="#1E1E1E" CornerRadius="20" BorderThickness="1" SnapsToDevicePixels="True" Margin="5">
        <Border.Effect>
            <DropShadowEffect
            BlurRadius="10"
            ShadowDepth="0"
            Color="Black"
            Opacity="0.5"
            RenderingBias="Quality"/>
        </Border.Effect>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                <GradientStop Color="LightGray" Offset="0" />
                <GradientStop Color="Transparent" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.3*" /> <!-- header -->
                <RowDefinition Height="0.1*" /> <!-- spacer -->
                <RowDefinition Height="*" /> <!-- main body -->
                <RowDefinition Height="0.1*" /> <!-- spacer -->
                <RowDefinition Height="0.4*" /> <!-- buttons -->
            </Grid.RowDefinitions>
            
            <!-- header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.1*" />                    <!-- symbol -->
                    <ColumnDefinition Width="*" />                    <!-- message -->
                </Grid.ColumnDefinitions>

                <!-- symbol -->
                <Grid Grid.Column="0">

                </Grid>

                <!-- message -->
                <Grid Grid.Column="1">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,0,0" Text="Error" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                </Grid>
                
            </Grid>

            <!-- spacer -->
            <Grid Grid.Row="1" />
            
            <!-- main body -->
            <Grid Grid.Row="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Width="350">
                    <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Hellow Worl" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="Medium" Foreground="{StaticResource FontSecondaryBrush}" FontSize="16" />
                </ScrollViewer>            
            </Grid>

            <!-- spacer -->
            <Grid Grid.Row="3" />

            <!-- buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /> <!-- cancel -->
                    <ColumnDefinition Width="*" /> <!-- OK -->
                </Grid.ColumnDefinitions>
                <!-- cancel -->
                <Grid Grid.Column="0" Margin="5,0">
                    <Border x:Name="CancelBorder" MouseLeave="CancelBorder_MouseLeave" MouseLeftButtonUp="CancelBorder_MouseLeftButtonUp" MouseLeftButtonDown="CancelBorder_MouseLeftButtonDown" SnapsToDevicePixels="True" BorderThickness="1" Background="#1E1E1E" VerticalAlignment="Center" CornerRadius="10" Height="40">
                        <Border.Style>
                            <Style TargetType="Border">
                                <!-- 1. Base Background (rgba 255,255,255, 0.05) -->
                                <Setter Property="Background" Value="#0DFFFFFF" />

                                <!-- 2. The 1px Gradient Border -->
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <!-- Top Highlight -->
                                            <GradientStop Color="#40FFFFFF" Offset="0" />
                                            <!-- Bottom Fade -->
                                            <GradientStop Color="#05FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <!-- 3. Hover State -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <!-- Increase opacity to rgba 255,255,255, 0.1 -->
                                        <Setter Property="Background" Value="#1AFFFFFF" />
                                        <Setter Property="Cursor" Value="Hand" />

                                        <!-- 4. Subtle Glow -->
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="10" 
                                                    Color="LightGray" 
                                                    Opacity="0.15" 
                                                    ShadowDepth="0" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0" Text="Cancel" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Medium" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#888888"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=CancelBorder}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>

                <!-- OK -->
                <Grid Grid.Column="1" Margin="5,0">
                    <Border x:Name="OKBorder" MouseLeave="OKBorder_MouseLeave" MouseLeftButtonUp="OKBorder_MouseLeftButtonUp" MouseLeftButtonDown="OKBorder_MouseLeftButtonDown" SnapsToDevicePixels="True" BorderThickness="1" Background="#1E1E1E" VerticalAlignment="Center" CornerRadius="10" Height="40">
                        <Border.Style>
                            <Style TargetType="Border">
                                <!-- 1. Base Background (rgba 255,255,255, 0.05) -->
                                <Setter Property="Background" Value="#0DFFFFFF" />

                                <!-- 2. The 1px Gradient Border -->
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <!-- Top Highlight -->
                                            <GradientStop Color="#40FFFFFF" Offset="0" />
                                            <!-- Bottom Fade -->
                                            <GradientStop Color="#05FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <!-- 3. Hover State -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <!-- Increase opacity to rgba 255,255,255, 0.1 -->
                                        <Setter Property="Background" Value="#1AFFFFFF" />
                                        <Setter Property="Cursor" Value="Hand" />

                                        <!-- 4. Subtle Glow -->
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="10" 
                                                    Color="LightGray" 
                                                    Opacity="0.15" 
                                                    ShadowDepth="0" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0" Text="Ok" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Medium" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#888888"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=OKBorder}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
