                            <Border.Style>
                                <Style TargetType="Border">
                                    <!-- DEFAULT STATE -->
                                    <Setter Property="BorderBrush">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                                <GradientStop Color="LightGray" Offset="0" />
                                                <GradientStop Color="Transparent" Offset="1" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>

                                    <!-- HOVER STATE -->
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <svg:SvgViewbox Margin="2,2,0,0" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/chevron-right.svg" Width="20" Height="20"/>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        <!--#endregion-->
    </Grid>
