<UserControl x:Class="Traker.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:conv="clr-namespace:Traker.Converters"
             xmlns:local="clr-namespace:Traker.Views"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:cal="http://caliburnmicro.com"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="800">

    <UserControl.Resources>
        <conv:BoolToVisibilityCollapsed x:Key="BoolToVisCollapsed"/>
    </UserControl.Resources>

    <Grid>
        <!--#region user setup-->
        <Border Height="800" Width="1000" Visibility="{Binding SetupWindows[0], Converter={StaticResource BoolToVisCollapsed}}" Background="#1E1E1E" CornerRadius="20" BorderThickness="1" SnapsToDevicePixels="True">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                    <GradientStop Color="LightGray" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid Margin="30,20,30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.2*" />                    <!-- top bar        -->
                    <RowDefinition Height="auto" />                    <!-- main contents       -->
                    <RowDefinition Height="0.15*" />                    <!-- buttons        -->
                </Grid.RowDefinitions>

                <!-- top bar -->
                <Grid Grid.Row="0">
                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Welcome to TRAKER" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontPrimaryBrush}" FontSize="58" />
                </Grid>

                <!-- main contents -->
                <Grid Grid.Row="1" VerticalAlignment="Center" Margin="80,0,80,0">
                    <Grid Margin="30,0,30,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />                            <!-- instructions -->
                            <RowDefinition Height="auto" />                            <!-- details -->
                        </Grid.RowDefinitions>

                        <!-- instructions -->
                        <Grid Grid.Row="0">

                        </Grid>

                        <!-- details -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />                                <!-- user info -->
                                <RowDefinition Height="auto" />                                <!-- type -->
                            </Grid.RowDefinitions>

                            <!-- user info -->
                            <Grid Grid.Row="0">
                                <Border Background="#242424" CornerRadius="15" BorderThickness="1.5" Margin="40,20" SnapsToDevicePixels="True">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="LightGray" Opacity="0.25" />
                                    </Border.BorderBrush>
                                    <Grid Margin="30">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />                                            <!-- name -->
                                            <RowDefinition Height="auto" />                                            <!-- email -->
                                            <RowDefinition Height="auto" />                                            <!-- phone -->
                                            <RowDefinition Height="auto" />                                            <!-- type -->
                                        </Grid.RowDefinitions>

                                        <!-- name -->
                                        <Grid Grid.Row="1" Margin="0,0,0,25">
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Margin="5,0,0,5" Text="Full Name" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                                <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- email -->
                                        <Grid Grid.Row="2" Margin="0,0,0,25">
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Margin="5,0,0,5" Text="Email" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                                <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- phone -->
                                        <Grid Grid.Row="3">
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Margin="5,0,0,5" Text="Phone" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                                <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- type -->
                            <Grid Grid.Row="1">
                                <Border Background="#242424" CornerRadius="15" BorderThickness="1.5" Margin="40,20" SnapsToDevicePixels="True">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="LightGray" Opacity="0.25" />
                                    </Border.BorderBrush>
                                    <Grid Margin="30">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                        </Grid.RowDefinitions>

                                        <!-- title -->
                                        <Grid Grid.Row="0" Margin="0,0,0,25">
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Text="Busienss Type" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontPrimaryBrush}" FontSize="28" />
                                        </Grid>

                                        <!-- spacer -->
                                        <Grid Grid.Row="1" />

                                        <Grid Grid.Row="2" HorizontalAlignment="Center">
                                            <Border Background="#1A1A1A" CornerRadius="25" BorderThickness="1.5" VerticalAlignment="Center" SnapsToDevicePixels="True">

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <!-- indiviudal -->
                                                    <Border IsEnabled="{Binding ToggleButtons[0]}" x:Name="Indvidualbtn" Cursor="Hand" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SetBusinessType('Individual')]" Background="{Binding BackgroundButtons[0]}" CornerRadius="25" Height="45" Width="200" Margin="0,0,100,0" BorderThickness="1">
                                                        <Border.BorderBrush>
                                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                                                <GradientStop Color="#FFFFFF" Offset="0" />
                                                                <GradientStop Color="Transparent" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.BorderBrush>
                                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Individual" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="Medium" FontSize="16">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <!-- Default State -->
                                                                    <Setter Property="Foreground" Value="{Binding ForegroundText[0]}" />

                                                                    <Style.Triggers>
                                                                        <!-- Watch the 'IsMouseOver' property of the element named 'MyBorder' -->
                                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=Indvidualbtn}" Value="True">
                                                                            <Setter Property="Foreground" Value="#CCCCCC" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>

                                                    <!-- company -->
                                                    <Border IsEnabled="{Binding ToggleButtons[1]}" x:Name="Companybtn" Cursor="Hand" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SetBusinessType('Company')]" Background="{Binding BackgroundButtons[1]}" CornerRadius="20" Height="45" Width="200" Margin="0,0,0,0" BorderThickness="1">
                                                        <Border.BorderBrush>
                                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                                                <GradientStop Color="#FFFFFF" Offset="0" />
                                                                <GradientStop Color="Transparent" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.BorderBrush>
                                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Company" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="Medium" FontSize="16">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <!-- Default State -->
                                                                    <Setter Property="Foreground" Value="{Binding ForegroundText[1]}" />

                                                                    <Style.Triggers>
                                                                        <!-- Watch the 'IsMouseOver' property of the element named 'MyBorder' -->
                                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=Companybtn}" Value="True">
                                                                            <Setter Property="Foreground" Value="#CCCCCC" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>                    
                </Grid>

                <!-- butons -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.5*" /> <!-- empty -->
                        <ColumnDefinition Width="*" /> <!-- stage -->
                        <ColumnDefinition Width="0.5*" /> <!-- next -->
                    </Grid.ColumnDefinitions>
                    
                    <!-- empty -->
                    <Grid Grid.Column="0">
                        
                    </Grid>
                    
                    <!-- stage -->
                    <Grid Grid.Column="1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <svg:SvgViewbox Margin="0,0,20,0" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/user-round.svg" Width="20" Height="20"/>
                            <svg:SvgViewbox Margin="0,0,20,0" Opacity="0.5" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/briefcase-business.svg" Width="15" Height="15"/>
                            <svg:SvgViewbox Margin="0,0,0,0" Opacity="0.5" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/landmark.svg" Width="15" Height="15"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- next -->
                    <Grid Grid.Column="2">
                        <!-- next -->
                        <Border IsEnabled="{Binding EnableNextBtn}" Opacity="{Binding OpacityBtn}" HorizontalAlignment="Right" Cursor="Hand" SnapsToDevicePixels="True" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action ConfirmUserSetup()]" Background="#333333" CornerRadius="25" Height="50" Width="50" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <!-- DEFAULT STATE -->
                                    <Setter Property="BorderBrush">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                                <GradientStop Color="LightGray" Offset="0" />
                                                <GradientStop Color="Transparent" Offset="1" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>

                                    <!-- HOVER STATE -->
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <svg:SvgViewbox Margin="2,2,0,0" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/chevron-right.svg" Width="20" Height="20"/>
                        </Border>
                    </Grid>    
                </Grid>
            </Grid>
        </Border>
        <!--#endregion-->

        <!--#region business setup -->
        <!--#region individual-->
        <Border Height="800" Width="1000" Visibility="{Binding SetupWindows[1], Converter={StaticResource BoolToVisCollapsed}}" Background="#1E1E1E" CornerRadius="20" BorderThickness="1" SnapsToDevicePixels="True">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                    <GradientStop Color="LightGray" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid Margin="30,20,30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.2*" />                    <!-- top bar        -->
                    <RowDefinition Height="auto" />                    <!-- main contents       -->
                    <RowDefinition Height="0.15*" />                    <!-- buttons        -->
                </Grid.RowDefinitions>

                <!-- top bar -->
                <Grid Grid.Row="0">
                    <!--<TextBlock HorizontalAlignment="Center" Text="Business Info" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>-->
                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Welcome to TRAKER" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontPrimaryBrush}" FontSize="58" />

                </Grid>

                <!-- main contents -->
                <Grid Grid.Row="1" VerticalAlignment="Center" Margin="80,30,80,30">
                    <Border Background="#242424" CornerRadius="15" BorderThickness="1.5"  Margin="70,0" SnapsToDevicePixels="True">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="LightGray" Opacity="0.25" />
                        </Border.BorderBrush>

                        <Grid Margin="30,20,30,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />                                <!-- name -->
                                <RowDefinition Height="auto" />                                <!-- country -->
                                <RowDefinition Height="auto" />                                <!-- city -->
                                <RowDefinition Height="auto" />                                <!-- address -->
                                <RowDefinition Height="auto" />                                <!-- postcode -->
                            </Grid.RowDefinitions>

                            <!-- name -->
                            <Grid Grid.Row="0" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Business Name" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Opacity="0.6" IsHitTestVisible="False" Focusable="False" Style="{DynamicResource TextBoxNormal}" Text="{Binding BusinessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>

                            <!-- country -->
                            <Grid Grid.Row="1" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Country" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Country, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>

                            <!-- city -->
                            <Grid Grid.Row="2" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="City" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>

                            <!-- address -->
                            <Grid Grid.Row="3" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Address" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>

                            <!-- postcode -->
                            <Grid Grid.Row="4" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Postcode" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Postcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- butons -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.5*" />
                        <!-- empty -->
                        <ColumnDefinition Width="*" />
                        <!-- stage -->
                        <ColumnDefinition Width="0.5*" />
                        <!-- next -->
                    </Grid.ColumnDefinitions>

                    <!-- empty -->
                    <Grid Grid.Column="0">

                    </Grid>

                    <!-- stage -->
                    <Grid Grid.Column="1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <svg:SvgViewbox Margin="0,0,20,0" Opacity="0.5" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/user-round.svg" Width="15" Height="15"/>
                            <svg:SvgViewbox Margin="0,0,20,0" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/briefcase-business.svg" Width="20" Height="20"/>
                            <svg:SvgViewbox Margin="0,0,0,0" Opacity="0.5" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/landmark.svg" Width="15" Height="15"/>
                        </StackPanel>
                    </Grid>

                    <!-- next -->
                    <Grid Grid.Column="2">
                        <Border IsEnabled="{Binding EnableNextBtn}" Opacity="{Binding OpacityBtn}" HorizontalAlignment="Right" Cursor="Hand" SnapsToDevicePixels="True" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action ConfirmBusinessSetup()]" Background="#333333" CornerRadius="25" Height="50" Width="50" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <!-- DEFAULT STATE -->
                                    <Setter Property="BorderBrush">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                                <GradientStop Color="LightGray" Offset="0" />
                                                <GradientStop Color="Transparent" Offset="1" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>

                                    <!-- HOVER STATE -->
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <svg:SvgViewbox Margin="2,2,0,0" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/chevron-right.svg" Width="20" Height="20"/>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        <!--#endregion-->

        <!--#region company -->
        <Border Height="800" Width="1000" Visibility="{Binding SetupWindows[2], Converter={StaticResource BoolToVisCollapsed}}" Background="#1E1E1E" CornerRadius="20" BorderThickness="1" SnapsToDevicePixels="True">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                    <GradientStop Color="LightGray" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid Margin="30,20,30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.2*" />                    <!-- top bar        -->
                    <RowDefinition Height="auto" />                    <!-- main contents       -->
                    <RowDefinition Height="0.15*" />                    <!-- buttons        -->
                </Grid.RowDefinitions>

                <!-- top bar -->
                <Grid Grid.Row="0">
                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Welcome to TRAKER" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontPrimaryBrush}" FontSize="58" />
                </Grid>

                <!-- main contents -->
                <Grid Grid.Row="1" VerticalAlignment="Center" Margin="80,30,80,30">
                    <Border Background="#242424" CornerRadius="15" BorderThickness="1.5"  Margin="70,0" SnapsToDevicePixels="True">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="LightGray" Opacity="0.25" />
                        </Border.BorderBrush>

                        <Grid Margin="30,20,30,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />                                <!-- name -->
                                <RowDefinition Height="auto" />                                <!-- country / city -->
                                <RowDefinition Height="auto" />                                <!-- address -->
                                <RowDefinition Height="auto" />                                <!-- postcode -->
                                <RowDefinition Height="auto" />                                <!-- VAT / Reg -->
                            </Grid.RowDefinitions>

                            <!-- name -->
                            <Grid Grid.Row="0" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Business Name" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding BusinessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>

                            <!-- country / city -->
                            <Grid Grid.Row="1" Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />                                    <!-- country -->
                                    <ColumnDefinition Width="*" />                                    <!-- city -->
                                </Grid.ColumnDefinitions>

                                <!-- country -->
                                <Grid Grid.Column="0" Margin="0,0,5,0">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="5,0,0,5" Text="Country" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                        <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Country, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

                                <!-- city -->
                                <Grid Grid.Column="1" Margin="5,0,0,0">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="5,0,0,5" Text="City" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                        <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <!-- address -->
                            <Grid Grid.Row="2" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Address" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>

                            <!-- postcode -->
                            <Grid Grid.Row="3" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Postcode" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Postcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>

                            <!-- vat / reg -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />                                    <!-- vat -->
                                    <ColumnDefinition Width="*" />                                    <!-- reg -->
                                </Grid.ColumnDefinitions>

                                <!-- vat -->
                                <Grid Grid.Column="0">
                                    <StackPanel Orientation="Vertical" Margin="0,0,5,0">
                                        <TextBlock Margin="5,0,0,5" Text="VAT Number" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
