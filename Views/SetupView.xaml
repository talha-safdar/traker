        <!--#region bank setup -->
        <Border Height="800" Width="1000" Visibility="{Binding SetupWindows[3], Converter={StaticResource BoolToVisCollapsed}}" Background="#1E1E1E" CornerRadius="20" BorderThickness="1" SnapsToDevicePixels="True">
