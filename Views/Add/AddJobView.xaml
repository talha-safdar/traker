<UserControl x:Class="Traker.Views.Add.AddJobView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:local="clr-namespace:Traker.Views" xmlns:viewmodels="clr-namespace:Traker.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:AddJobViewModel}"
             mc:Ignorable="d" 
             xmlns:conv="clr-namespace:Traker.Converters"
             d:DesignHeight="600" 
             d:DesignWidth="500"
             MaxHeight="700"
             MaxWidth="550"
             >
    <Border Background="#1E1E1E" CornerRadius="20" BorderThickness="1" SnapsToDevicePixels="True">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                <GradientStop Color="LightGray" Offset="0" />
                <GradientStop Color="Transparent" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Grid Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.1*" />                <!-- top bar        -->
                <RowDefinition Height="*" />                <!-- main contents       -->
                <RowDefinition Height="0.15*" />                <!-- buttons        -->
            </Grid.RowDefinitions>

            <!-- top bar -->
            <Grid Grid.Row="0">
                <Border Cursor="Hand" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action Exit()]" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="20" Height="35" Width="35">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#404040"/>
                            <Setter Property="Opacity" Value="0.5"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <svg:SvgViewbox                         
                RenderOptions.BitmapScalingMode="HighQuality"
                SnapsToDevicePixels="True"
                Source="/Resources/Media/Images/Icons/Lucide/x.svg" Width="15" Height="15"/>
                </Border>
            </Grid>

            <!-- main contents -->
            <Grid Grid.Row="1">
                <Border Background="#242424" CornerRadius="15" BorderThickness="1.5" Margin="50,20" SnapsToDevicePixels="True">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="LightGray" Opacity="0.25" />
                    </Border.BorderBrush>
                    <Grid Margin="20,0" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />                            <!-- client selection -->
                            <RowDefinition Height="*" />                            <!-- job title -->
                            <RowDefinition Height="*" />                            <!-- price -->
                            <RowDefinition Height="*" />                            <!-- due date -->
                        </Grid.RowDefinitions>

                        <!-- client selection -->
                        <Grid Grid.Row="0" Margin="0,0,0,25">
                            <StackPanel Orientation="Vertical">
                                <TextBlock VerticalAlignment="Center" Margin="5,0,0,5" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22">
                                <Run Text="Number of Clients: " />
                                    <Run Text="{Binding AddJob.Count, Mode=OneWay}" />
                                </TextBlock>
                                <ComboBox Style="{DynamicResource ComboBoxNormal}"
                                      IsEditable="False"
                                      FontWeight="Regular"
                                      HorizontalAlignment="Stretch" 
                                      FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans"
                                      ItemsSource="{Binding AddJob}"
                                      SelectedItem="{Binding SelectedClient, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,10" HorizontalAlignment="Stretch">
                                                <TextBlock Text="{Binding FullName}"
                                                    FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="Regular" 
                                                    FontSize="22"/>
                                                                                <TextBlock Width="400" FontSize="18" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Medium" Opacity="0.7">
                                                        <Run Text="Created Date: " />
                                                        <Run Text="{Binding CreatedDate}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- job title -->
                        <Grid Grid.Row="1" Margin="0,0,0,25">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Margin="5,0,0,5" Text="Job Title" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding JobTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                            </StackPanel>
                        </Grid>


                        <!-- price -->
                        <Grid Grid.Row="2" Margin="0,0,0,25">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Margin="5,0,0,5" Text="Price" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                            </StackPanel>
                        </Grid>

                        <!-- due date -->
                        <Grid Grid.Row="3" Margin="0,0,0,0">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Margin="5,0,0,5" Text="Due Date" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding DueDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- butons -->
            <Grid Grid.Row="2">
                <Border Cursor="Hand" SnapsToDevicePixels="True" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action AddJobToClient()]" Background="#333333" CornerRadius="25" Height="45" Margin="150,0" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <!-- DEFAULT STATE -->
                            <Setter Property="BorderBrush">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                        <GradientStop Color="LightGray" Offset="0" />
                                        <GradientStop Color="Transparent" Offset="1" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>

                            <!-- HOVER STATE -->
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock conv:TextBlockSpacer.LetterSpacing="2.01" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Add Job" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="16" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
