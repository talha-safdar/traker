<UserControl x:Class="Traker.Views.User.UserContextMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:local="clr-namespace:Traker.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="#1E1E1E" CornerRadius="15" BorderThickness="1" Width="295" Height="190" VerticalAlignment="Center">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                <GradientStop Color="LightGray" Offset="0" />
                <GradientStop Color="Transparent" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>

        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="10,10,10,0">
            <Border Cursor="Hand" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action OpenOption('user')]" CornerRadius="20" Height="40" Margin="5,0,5,15" Background="#242424" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="#242424"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Border Opacity="0.5" Background="Transparent"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="28" Width="28">
                        <svg:SvgViewbox                         
                            RenderOptions.BitmapScalingMode="HighQuality"
                            SnapsToDevicePixels="True"
                            Source="/Resources/Media/Images/Icons/Lucide/user-round.svg" Width="15" Height="15"/>
                    </Border>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" Text="User" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                </StackPanel>
            </Border>
            
            <Border Cursor="Hand" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action OpenOption('business')]" CornerRadius="20" Height="40" Margin="5,0,5,15" Background="#242424" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="#242424"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Border Opacity="0.5" Background="Transparent"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="28" Width="28">
                        <svg:SvgViewbox                         
                            RenderOptions.BitmapScalingMode="HighQuality"
                            SnapsToDevicePixels="True"
                            Source="/Resources/Media/Images/Icons/Lucide/briefcase-business.svg" Width="15" Height="15"/>
                    </Border>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" Text="Business" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                </StackPanel>
            </Border>
            <Border Cursor="Hand" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action OpenOption('bank')]" CornerRadius="20" Height="40" Margin="5,0,5,15" Background="#242424" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="#242424"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Border Opacity="0.5" Background="Transparent"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="28" Width="28">
                        <svg:SvgViewbox                         
                            RenderOptions.BitmapScalingMode="HighQuality"
                            SnapsToDevicePixels="True"
                            Source="/Resources/Media/Images/Icons/Lucide/landmark.svg" Width="15" Height="15"/>
                    </Border>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" Text="Bank" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="Regular" Foreground="#E4E4E7" FontSize="14" />
                </StackPanel>
                
                
                
                
            </Border>
        </StackPanel>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="2"/>
        </Border.Effect>
    </Border>
    
