<UserControl x:Class="Traker.Views.User.BusinessInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Traker.Converters"
             xmlns:local="clr-namespace:Traker.Views"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:cal="http://caliburnmicro.com"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <conv:BoolToVisibilityCollapsed x:Key="BoolToVisCollapsed"/>
    </UserControl.Resources>

    <Grid Height="800" Width="1000">
        <!--#region individual-->
        <Border Visibility="{Binding IndividualView, Converter={StaticResource BoolToVisCollapsed}}" Background="#1E1E1E" CornerRadius="20" BorderThickness="1" SnapsToDevicePixels="True">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                    <GradientStop Color="LightGray" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>


            <Grid Margin="30,20,30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.1*" />                <!-- top bar        -->
                    <RowDefinition Height="*" />                <!-- main contents       -->
                    <RowDefinition Height="0.15*" />                <!-- buttons        -->
                </Grid.RowDefinitions>

                <!-- top bar -->
                <Grid Grid.Row="0">
                    <!-- close -->
                    <Border Cursor="Hand" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action Exit()]" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="20" Height="35" Width="35">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#404040"/>
                                <Setter Property="Opacity" Value="0.5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <svg:SvgViewbox RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/x.svg" Width="15" Height="15"/>
                    </Border>
                </Grid>

                <!-- main contents -->
                <Grid Grid.Row="1" VerticalAlignment="Center" Margin="80,0,80,0">
                    <Border Background="#242424" CornerRadius="15" BorderThickness="1.5" Margin="40,20" SnapsToDevicePixels="True">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="LightGray" Opacity="0.25" />
                        </Border.BorderBrush>
                        
                        <Grid Margin="30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" /> <!-- name -->
                                <RowDefinition Height="auto" /> <!-- country -->
                                <RowDefinition Height="auto" /> <!-- city -->
                                <RowDefinition Height="auto" /> <!-- address -->
                                <RowDefinition Height="auto" /> <!-- postcode -->
                            </Grid.RowDefinitions>
                        
                            <!-- name -->
                            <Grid Grid.Row="0" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Business Name" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Opacity="0.6" IsHitTestVisible="False" Focusable="False" Style="{DynamicResource TextBoxNormal}" Text="{Binding BusinessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>

                            <!-- country -->
                            <Grid Grid.Row="1" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Country" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Country, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>                            
                            </Grid>

                            <!-- city -->
                            <Grid Grid.Row="2" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="City" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>                            
                            </Grid>

                            <!-- address -->
                            <Grid Grid.Row="3" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Address" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>
                        
                            <!-- postcode -->
                            <Grid Grid.Row="4" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Postcode" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Postcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>                            
                            </Grid>
                        </Grid>                    
                    </Border>
                </Grid>

                <!-- butons -->
                <Grid Grid.Row="2">
                    <!-- save -->
                    <Grid Grid.Column="2">
                        <Border Cursor="Hand" SnapsToDevicePixels="True" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action ConfirmBusinessInfoChanges()]" Background="#333333" CornerRadius="23" Height="45" Width="200" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <!-- DEFAULT STATE -->
                                    <Setter Property="BorderBrush">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                                <GradientStop Color="LightGray" Offset="0" />
                                                <GradientStop Color="Transparent" Offset="1" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>

                                    <!-- HOVER STATE -->
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock conv:TextBlockSpacer.LetterSpacing="2.01" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Save Changes" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="18" />
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        <!--#endregion-->

        <!--#region company -->
        <Border Visibility="{Binding CompanyView, Converter={StaticResource BoolToVisCollapsed}}" Background="#1E1E1E" CornerRadius="20" BorderThickness="1">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                    <GradientStop Color="LightGray" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid Margin="30,20,30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.1*" />                    <!-- top bar        -->
                    <RowDefinition Height="*" />                    <!-- main contents       -->
                    <RowDefinition Height="0.15*" />                    <!-- buttons        -->
                </Grid.RowDefinitions>

                <!-- top bar -->
                <Grid Grid.Row="0">
                    <!-- close -->
                    <Border Cursor="Hand" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action Exit()]" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="20" Height="35" Width="35">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#404040"/>
                                <Setter Property="Opacity" Value="0.5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <svg:SvgViewbox RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/x.svg" Width="15" Height="15"/>
                    </Border>
                </Grid>

                <!-- main contents -->
                <Grid Grid.Row="1" VerticalAlignment="Center" Margin="80,0,80,0">
                    <Border Background="#242424" CornerRadius="15" BorderThickness="1.5" Margin="40,20" SnapsToDevicePixels="True">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="LightGray" Opacity="0.25" />
                        </Border.BorderBrush>
                        <Grid Margin="30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />                                <!-- name -->
                                <RowDefinition Height="auto" />                                <!-- country / city -->
                                <RowDefinition Height="auto" />                                <!-- address -->
                                <RowDefinition Height="auto" />                                <!-- postcode -->
                                <RowDefinition Height="auto" />                                <!-- VAT / Reg -->
                            </Grid.RowDefinitions>

                            <!-- name -->
                            <Grid Grid.Row="0" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Business Name" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding BusinessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>

                            <!-- country / city -->
                            <Grid Grid.Row="1" Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />                                    <!-- country -->
                                    <ColumnDefinition Width="*" />                                    <!-- city -->
                                </Grid.ColumnDefinitions>

                                <!-- country -->
                                <Grid Grid.Column="0" Margin="0,0,5,0">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="5,0,0,5" Text="Country" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                        <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Country, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

                                <!-- city -->
                                <Grid Grid.Column="1" Margin="5,0,0,0">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="5,0,0,5" Text="City" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                        <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <!-- address -->
                            <Grid Grid.Row="2" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Address" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>

                            <!-- postcode -->
                            <Grid Grid.Row="3" Margin="0,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Postcode" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding Postcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>

                            <!-- vat / reg -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />                                    <!-- vat -->
                                    <ColumnDefinition Width="*" />                                    <!-- reg -->
                                </Grid.ColumnDefinitions>

                                <!-- vat -->
                                <Grid Grid.Column="0">
                                    <StackPanel Orientation="Vertical" Margin="0,0,5,0">
                                        <TextBlock Margin="5,0,0,5" Text="VAT Number" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                        <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding VatNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

                                <!-- reg -->
                                <Grid Grid.Column="1">
                                    <StackPanel Orientation="Vertical" Margin="5,0,0,0">
                                        <TextBlock Margin="5,0,0,5" Text="Registration Number" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                        <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding RegistrationNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- butons -->
                <Grid Grid.Row="2">
                    <!-- save -->
                    <Grid Grid.Column="2">
                        <Border Cursor="Hand" SnapsToDevicePixels="True" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action ConfirmBusinessInfoChanges()]" Background="#333333" CornerRadius="23" Height="45" Width="200" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <!-- DEFAULT STATE -->
                                    <Setter Property="BorderBrush">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                                <GradientStop Color="LightGray" Offset="0" />
                                                <GradientStop Color="Transparent" Offset="1" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>

                                    <!-- HOVER STATE -->
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock conv:TextBlockSpacer.LetterSpacing="2.01" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Save Changes" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="18" />
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        <!--#endregion-->
    </Grid>
</UserControl>
