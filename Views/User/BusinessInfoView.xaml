<UserControl x:Class="Traker.Views.User.BusinessInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:UltraAnalysis.Converters"
             xmlns:local="clr-namespace:Traker.Views"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:cal="http://caliburnmicro.com"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <conv:BoolToVisibilityCollapsed x:Key="BoolToVisCollapsed"/>
    </UserControl.Resources>

    <Grid>
        <!--#region individual-->
        <Border Visibility="{Binding IndividualView, Converter={StaticResource BoolToVisCollapsed}}" Background="{StaticResource BorderBrush}" CornerRadius="20" BorderThickness="5" BorderBrush="{StaticResource LightBorderBrush}">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.12*" />                    <!-- top bar -->
                    <RowDefinition Height="0.12*" />                    <!-- spacer -->
                    <RowDefinition Height="*" />                    <!-- main content -->
                    <RowDefinition Height="0.5*" />                    <!-- buttons -->
                </Grid.RowDefinitions>

                <!-- top bar -->
                <Grid Grid.Row="0" Margin="30,20,30,0" Height="50">
                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Text="| Business Information" Opacity="0.7" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontPrimaryBrush}" FontSize="58" />
                    <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action Exit()]" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="20" Height="20" Width="20">
                        <svg:SvgViewbox                         
                RenderOptions.BitmapScalingMode="HighQuality"
                SnapsToDevicePixels="True"
                Source="/Resources/Media/Images/Icons/Lucide/x.svg" Width="15" Height="15"/>
                    </Border>
                </Grid>

                <!-- spacer -->
                <Grid Grid.Row="1" />

                <!-- main content -->
                <Grid Grid.Row="2" Height="620" Width="1000">
                    <!-- contents go here -->
                    <Grid Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="#494949" CornerRadius="20" Margin="100,0" Padding="30" Width="600" Height="500">
                            <StackPanel Orientation="Vertical" Margin="0" VerticalAlignment="Center" >
                                <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                                    <TextBlock Margin="5,0,0,0" Text="Business Name" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                    <TextBox Text="{Binding BusinessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Opacity="{Binding BusinessNameOpacity}" IsReadOnly="{Binding IndividualView}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                                    <TextBlock Margin="5,0,0,0" Text="Country" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                    <TextBox Text="{Binding Country, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                                    <TextBlock Margin="5,0,0,0" Text="City" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                    <TextBox Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                                    <TextBlock Margin="5,0,0,0" Text="Address" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                    <TextBox Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,0" Text="Postcode" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                    <TextBox Text="{Binding Postcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- buttons -->
                <Grid Grid.Row="4">
                    <Border Background="#181818" CornerRadius="0,0,20,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action CancelEditClient()]" Background="Transparent" CornerRadius="25" Height="40" Width="150" Margin="0,0,30,0" BorderThickness="2" BorderBrush="Red">
                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Cancel" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="Bold" Foreground="Red" FontSize="16" />
                            </Border>
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action ConfirmEditClient()]" Background="Green" CornerRadius="25" Height="40" Width="150" Margin="0,0,0,0" BorderThickness="2" BorderBrush="Green">
                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Confirm" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="Bold" Foreground="{StaticResource FontPrimaryBrush}" FontSize="16" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
        <!--#endregion-->

        <!--#region company -->
        <Border Visibility="{Binding CompanyView, Converter={StaticResource BoolToVisCollapsed}}" Background="{StaticResource BorderBrush}" CornerRadius="20" BorderThickness="5" BorderBrush="{StaticResource LightBorderBrush}">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.12*" />                    <!-- top bar -->
                    <RowDefinition Height="0.12*" />                    <!-- spacer -->
                    <RowDefinition Height="*" />                    <!-- main content -->
                    <RowDefinition Height="0.5*" />                    <!-- buttons -->
                </Grid.RowDefinitions>

                <!-- top bar -->
                <Grid Grid.Row="0" Margin="30,20,30,0" Height="50">
                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Text="| Business Information" Opacity="0.7" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontPrimaryBrush}" FontSize="58" />
                    <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action Exit()]" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="20" Height="20" Width="20">
                        <svg:SvgViewbox                         
                        RenderOptions.BitmapScalingMode="HighQuality"
                        SnapsToDevicePixels="True"
                        Source="/Resources/Media/Images/Icons/Lucide/x.svg" Width="15" Height="15"/>
                    </Border>
                </Grid>

                <!-- spacer -->
                <Grid Grid.Row="1" />

                <!-- main content -->
                <Grid Grid.Row="2" Height="620" Width="1000">
                    <!-- contents go here -->
                    <Grid Margin="20"  HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="#494949" CornerRadius="20" Margin="100,0" Padding="30" Width="600" Height="500">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- business name -->                                
                                <Grid Grid.Row="0" Grid.ColumnSpan="2">
                                    <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                                        <TextBlock Margin="5,0,0,0" Text="Business Name" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                        <TextBox Text="{Binding BusinessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

        
                                                        <!-- country -->                                
                                <Grid Grid.Row="1" Grid.Column="0">
                                    <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                                        <TextBlock Margin="5,0,0,0" Text="Country" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                        <TextBox Text="{Binding Country, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

        
                                                        <!-- city -->                                
                                <Grid Grid.Row="1" Grid.Column="1">
                                    <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                                        <TextBlock Margin="5,0,0,0" Text="City" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                        <TextBox Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

        
                                                        <!-- address -->                                
                                <Grid Grid.Row="2" Grid.ColumnSpan="2">
                                    <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                                        <TextBlock Margin="5,0,0,0" Text="Address" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                        <TextBox Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

        
                                                        <!-- postcode -->                                
                                <Grid Grid.Row="3" Grid.ColumnSpan="2">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="5,0,0,0" Text="Postcode" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                        <TextBox Text="{Binding Postcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

                               
                                                        <!-- VAT number -->                                
                                <Grid Grid.Row="4" Grid.Column="0">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="5,0,0,0" Text="VAT Number" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                        <TextBox Text="{Binding VatNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>

        
                                                        <!-- registration number -->                                
                                <Grid Grid.Row="4" Grid.Column="1">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="5,0,0,0" Text="Registration Number" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="22" />
                                        <TextBox Text="{Binding RegistrationNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>            
                    </Grid>
                </Grid>

                <!-- buttons -->
                <Grid Grid.Row="4">
                    <Border Background="#181818" CornerRadius="0,0,20,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action CancelEditClient()]" Background="Transparent" CornerRadius="25" Height="40" Width="150" Margin="0,0,30,0" BorderThickness="2" BorderBrush="Red">
                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Cancel" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="Bold" Foreground="Red" FontSize="16" />
                            </Border>
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action ConfirmBusinessInfoChanges()]" Background="Green" CornerRadius="25" Height="40" Width="150" Margin="0,0,0,0" BorderThickness="2" BorderBrush="Green">
                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" Text="Confirm" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="Bold" Foreground="{StaticResource FontPrimaryBrush}" FontSize="16" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
        <!--#endregion-->
    </Grid>
</UserControl>
