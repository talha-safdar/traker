<UserControl x:Class="Traker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:local="clr-namespace:Traker.Views" xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <!--
        
    use staticresource for static styles
    and dyanmicresource for theme changing
    
    -->
    
    <Grid Background="{StaticResource MainBackgroundBrush}" cal:Message.Attach="[Event PreviewMouseDown] = [Action OnMouseDownEvent($source)]">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.235*" /> <!-- side panel -->
            <ColumnDefinition Width="*" /> <!-- main panel -->
        </Grid.ColumnDefinitions>
            
        <!-- side panel -->
        <Grid Grid.Column="0" Margin="20,20,10,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.1*" /> <!-- buttons -->
                <RowDefinition Height="*" /> <!-- information status -->
            </Grid.RowDefinitions>

            <!-- buttons -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <!-- panel container -->
                <Border CornerRadius="15" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="2">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- edit clients -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,20,0">
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action EditClient()]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/user-round.svg" Width="25" Height="25"/>
                            </Border>
                            <Border  Margin="-30,15,0,0">
                                <Border Background="#1E1E1E" CornerRadius="25" Margin="10">
                                    <svg:SvgViewbox                  
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/pen.svg" Width="15" Height="15"/>
                                </Border>
                            </Border>
                        </StackPanel>

                        <!-- edit jobs -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action EditJob('$source')]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/briefcase-business.svg" Width="25" Height="25"/>
                            </Border>
                            <Border  Margin="-30,15,0,0">
                                <Border Background="#1E1E1E" CornerRadius="25" Margin="10">
                                    <svg:SvgViewbox                  
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/pen.svg" Width="15" Height="15"/>
                                </Border>
                            </Border>
                        </StackPanel>

                        <!-- spacer -->
                        <Border Background="#555555" Width="2" Margin="20,10" />

                        <!-- add client -->
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,20,0">
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action AddClient()]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/user-round-plus.svg" Width="25" Height="25"/>
                            </Border>
                        </StackPanel>                            

                        <!-- add job -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action AddJob()]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/briefcase-business.svg" Width="25" Height="25"/>
                            </Border>
                            <Border  Margin="-30,15,0,0">
                                <Border Background="#1E1E1E" CornerRadius="25" Margin="10">
                                    <svg:SvgViewbox                  
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/plus.svg" Width="9" Height="9"/>
                                </Border>                                
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- infromation status -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <!-- panel container -->
                <Border CornerRadius="15" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="2">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" /> <!-- jobs information -->
                            <RowDefinition Height="0.15*" /> <!-- spacer -->
                            <RowDefinition Height="auto" /> <!-- money information -->
                            <RowDefinition Height="0.15*" /> <!-- spacer -->
                            <RowDefinition Height="auto" /> <!-- profile / account -->
                        </Grid.RowDefinitions>

                        <!-- jobs information -->
                        <Grid Grid.Row="0" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- new -->
                            <Grid Grid.Column="0" Grid.Row="0" Margin="0,0,0,20">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="New" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBlock Margin="5,0,0,0" Text="{Binding NewJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="42" />
                                </StackPanel>                                       
                            </Grid>
                            
                            <!-- active (in progress) -->
                            <Grid Grid.Column="1" Grid.Row="0" Margin="0,0,0,20">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Active" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBlock Margin="5,0,0,0" Text="{Binding ActiveJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="42" />
                                </StackPanel>
                            </Grid>

                            <!-- Done (completed) -->
                            <Grid Grid.Column="0" Grid.Row="1">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Done" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBlock Margin="5,0,0,0" Text="{Binding DoneJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="42" />
                                </StackPanel>
                            </Grid>                            

                            <!-- invoiced -->
                            <Grid Grid.Column="1" Grid.Row="1">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Invoiced" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBlock Margin="5,0,0,0" Text="{Binding InvoicedJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="42" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                        
                        <!-- spacer -->
                        <Grid Grid.Row="1">
                            <Border Margin="30,0" Opacity="0.3" Background="#555555" Height="2" />
                        </Grid>
                        
                        <!-- money information -->
                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" /> <!-- gross -->
                                <RowDefinition Height="*" /> <!-- received -->
                                <RowDefinition Height="*" /> <!-- overdue -->
                                <RowDefinition Height="*" /> <!-- outstanding -->
                            </Grid.RowDefinitions>
                            
                            <!-- gross payment -->
                            <Grid Grid.Row="0">
                                <StackPanel Orientation="Vertical" Margin="10,10,10,30">
                                    <TextBlock Margin="5,0,0,0" Text="Gross" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding GrossAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="32" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderThickness="0" />
                                </StackPanel>
                            </Grid>
                            
                            <!-- received payment -->
                            <Grid Grid.Row="1">
                                <StackPanel Orientation="Vertical" Margin="10,10,10,30">
                                    <TextBlock Margin="5,0,0,0" Text="Received" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding ReceivedAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="32" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderThickness="0" />
                                </StackPanel>
                            </Grid>              
                            
                            <!-- outstanding payment -->
                            <Grid Grid.Row="2">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Outstanding" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding OutstandingAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="32" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderThickness="0" />
                                </StackPanel>
                            </Grid>   
                            
                            <!-- overdue payment -->
                            <Grid Visibility="Collapsed" Grid.Row="3">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Overdue" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding OverdueAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="32" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderBrush="#3D3D3D" BorderThickness="2" />
                                </StackPanel>
                            </Grid>     
                        </Grid>

                        <!-- spacer -->
                        <Grid Grid.Row="3">
                            <Border Margin="30,0" Opacity="0.3"  Background="#555555" Height="2" />
                        </Grid>

                        <!-- profile / account -->
                        <Grid Grid.Row="4">
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action OpenUserContenxtMenu($source)]" Background="Black" CornerRadius="15" Height="65" Padding="5,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0,0,0">
                                    <Border Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                        <svg:SvgViewbox                         
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/user-round-cog.svg" Width="25" Height="25"/>
                                    </Border>
                                    <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Text="{Binding Data.User[0].FullName}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                </StackPanel>                                
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <!-- main panel -->
        <Grid Grid.Column="1" Margin="10,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.04*" /> <!-- search / filter / sort -->
                <RowDefinition Height="*" /> <!-- job cards -->
            </Grid.RowDefinitions>

            <!-- search / filter / sort -->
            <Grid Grid.Row="0" Margin="0,0,0,0">
                <Border CornerRadius="15" Background="Transparent" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0" >
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,5,0">
                        <Border Margin="0,0,10,0" Opacity="0.8" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action OpenFilterContextMenu($source)]" Background="{StaticResource SidePanelBackgroundBrush}" BorderBrush="{StaticResource FontPrimaryBrush}" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="35" Width="35">
                            <svg:SvgViewbox                         
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/list-filter.svg" Width="15" Height="15"/>
                        </Border>
                        <Border Opacity="0.8" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action OpenSortContextMenu($source)]" Background="{StaticResource SidePanelBackgroundBrush}" BorderBrush="{StaticResource FontPrimaryBrush}" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="35" Width="35">
                            <svg:SvgViewbox                         
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/arrow-up-down.svg" Width="15" Height="15"/>
                        </Border>                        
                    </StackPanel>
                </Border>
            </Grid>

            <!-- job cards -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Border Background="#121212" CornerRadius="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10" Padding="0,0,10,0">
                        <ItemsControl ItemsSource="{Binding DashboardData}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#242424" 
                            BorderThickness="1"
                            BorderBrush="#333333"
                            Height="135"
                        CornerRadius="10" 
                        Margin="0,0,0,10" 
                        Padding="10"
                        cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SelectJob($dataContext)];
                                            [Event MouseRightButtonUp] = [Action OpenContextMenu($dataContext)];"
                            Cursor="Hand"
                        MouseLeftButtonDown="EditJob">

                                        <Grid IsHitTestVisible="False">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.3*" />
                                                <!-- type -->
                                                <ColumnDefinition Width="*" />
                                                <!-- full name / job title -->
                                                <ColumnDefinition Width="0.2*" />
                                                <!-- spacer -->
                                                <ColumnDefinition Width="*" />
                                                <!-- job status / due date -->
                                                <ColumnDefinition Width="0.2*" />
                                                <!-- spacer -->
                                                <ColumnDefinition Width="*" />
                                                <!-- job price -->
                                            </Grid.ColumnDefinitions>

                                            <!-- type -->
                                            <Grid Grid.Column="0">
                                                <Border Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="80" Width="80">
                                                    <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="{Binding TypeIcon}" Width="40" Height="40"/>
                                                </Border>
                                            </Grid>

                                            <!-- full name / job title -->
                                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <!-- full name -->
                                                    <RowDefinition Height="*" />
                                                    <!-- spacer -->
                                                    <RowDefinition Height="*" />
                                                    <!-- job title -->
                                                </Grid.RowDefinitions>

                                                <!-- full name -->
                                                <Grid Grid.Row="0">
                                                    <TextBlock Margin="5,0,0,0" Text="{Binding ClientName}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Black" Foreground="{StaticResource FontPrimaryBrush}" FontSize="32" />
                                                </Grid>

                                                <!-- spacer -->
                                                <Grid Grid.Row="1" Margin="0,10" />

                                                <!-- job title -->
                                                <Grid Grid.Row="2">
                                                    <TextBlock Margin="5,0,0,0" Opacity="0.8" Text="{Binding JobTitle}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="24" />
                                                </Grid>
                                            </Grid>

                                            <!-- spacer-->
                                            <Grid Grid.Column="2">
                                                <Border Background="#555555" Width="2" Margin="0,10" />
                                            </Grid>

                                            <!-- job status / due date -->
                                            <Grid Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <!-- job status -->
                                                    <RowDefinition Height="0.5*" />
                                                    <!-- spacer -->
                                                    <RowDefinition Height="*" />
                                                    <!-- due date -->
                                                </Grid.RowDefinitions>

                                                <!-- job status -->
                                                <Grid Grid.Row="0">
                                                    <TextBlock Margin="0" Text="{Binding JobStatus}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Black" FontSize="32">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource FontPrimaryBrush}" />

                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding JobStatus}" Value="Invoiced">
                                                                        <Setter Property="Foreground" Value="LightBlue" />
                                                                        <Setter Property="FontWeight" Value="Bold" />
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding JobStatus}" Value="Done">
                                                                        <Setter Property="Foreground" Value="LightGreen" />
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding JobStatus}" Value="New">
                                                                        <Setter Property="Foreground" Value="LightCoral" />
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding JobStatus}" Value="Active">
                                                                        <Setter Property="Foreground" Value="DarkOrange" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>

                                                <!-- spacer -->
                                                <Grid Grid.Row="1" Margin="0,10" />

                                                <!-- due date -->
                                                <Grid Grid.Row="2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock HorizontalAlignment="Left" Margin="0" Text="Due" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="24" />
                                                        <TextBlock Margin="10,0,0,0" Text="{Binding DueDate}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="24" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>

                                            <!-- spacer -->
                                            <Grid Grid.Column="4">
                                                <Border Background="#555555" Width="2" Margin="0,10" />
                                            </Grid>

                                            <!-- job price -->
                                            <Grid Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Margin="0" Text="{Binding Price}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="Black" Foreground="{StaticResource FontPrimaryBrush}" FontSize="32" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
        
        <Grid Grid.Column="1" Margin="10,20,20,20">
            <!--<Border Background="#121212" CornerRadius="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10" Padding="0,0,10,0">
                    <ItemsControl ItemsSource="{Binding DashboardData}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#242424" 
                                        BorderThickness="1"
                                        BorderBrush="#333333"
                                        Height="135"
                                    CornerRadius="10" 
                                    Margin="0,0,0,10" 
                                    Padding="10"
                                    cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SelectJob($dataContext)];
                                                        [Event MouseRightButtonUp] = [Action OpenContextMenu($dataContext)];"
                                        Cursor="Hand"
                                    MouseLeftButtonDown="EditJob">

                                    <Grid IsHitTestVisible="False">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.3*" />                                            --><!-- type --><!--
                                            <ColumnDefinition Width="*" />                                            --><!-- full name / job title --><!--
                                            <ColumnDefinition Width="0.2*" />                                            --><!-- spacer --><!--
                                            <ColumnDefinition Width="*" />                                            --><!-- job status / due date --><!--
                                            <ColumnDefinition Width="0.2*" />                                            --><!-- spacer --><!--
                                            <ColumnDefinition Width="*" />                                            --><!-- job price --><!--
                                        </Grid.ColumnDefinitions>

                                        --><!-- type --><!--
                                        <Grid Grid.Column="0">
                                            <Border Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="80" Width="80">
                                                <svg:SvgViewbox                         
                                                RenderOptions.BitmapScalingMode="HighQuality"
                                                SnapsToDevicePixels="True"
                                                Source="{Binding TypeIcon}" Width="40" Height="40"/>
                                            </Border>
                                        </Grid>

                                        --><!-- full name / job title --><!--
                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />                                                --><!-- full name --><!--
                                                <RowDefinition Height="*" />                                                --><!-- spacer --><!--
                                                <RowDefinition Height="*" />                                                --><!-- job title --><!--
                                            </Grid.RowDefinitions>

                                            --><!-- full name --><!--
                                            <Grid Grid.Row="0">
                                                <TextBlock Margin="5,0,0,0" Text="{Binding ClientName}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Black" Foreground="{StaticResource FontPrimaryBrush}" FontSize="32" />
                                            </Grid>
                                            
                                            --><!-- spacer --><!--
                                            <Grid Grid.Row="1" Margin="0,10" />

                                            --><!-- job title --><!--
                                            <Grid Grid.Row="2">
                                                <TextBlock Margin="5,0,0,0" Opacity="0.8" Text="{Binding JobTitle}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="24" />
                                            </Grid>
                                        </Grid>

                                        --><!-- spacer--><!--
                                        <Grid Grid.Column="2">
                                            <Border Background="#555555" Width="2" Margin="0,10" />
                                        </Grid>

                                        --><!-- job status / due date --><!--
                                        <Grid Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />                                                --><!-- job status --><!--
                                                <RowDefinition Height="0.5*" />                                                --><!-- spacer --><!--
                                                <RowDefinition Height="*" />                                                --><!-- due date --><!--
                                            </Grid.RowDefinitions>

                                            --><!-- job status --><!--
                                            <Grid Grid.Row="0">
                                                <TextBlock Margin="0" Text="{Binding JobStatus}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Black" FontSize="32">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource FontPrimaryBrush}" />

                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding JobStatus}" Value="Invoiced">
                                                                    <Setter Property="Foreground" Value="LightBlue" />
                                                                    <Setter Property="FontWeight" Value="Bold" />
                                                                </DataTrigger>

                                                                <DataTrigger Binding="{Binding JobStatus}" Value="Done">
                                                                    <Setter Property="Foreground" Value="LightGreen" />
                                                                </DataTrigger>
                                                                
                                                                <DataTrigger Binding="{Binding JobStatus}" Value="New">
                                                                    <Setter Property="Foreground" Value="LightCoral" />
                                                                </DataTrigger>
                                                                
                                                                <DataTrigger Binding="{Binding JobStatus}" Value="Active">
                                                                    <Setter Property="Foreground" Value="DarkOrange" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>

                                            --><!-- spacer --><!--
                                            <Grid Grid.Row="1" Margin="0,10" />

                                            --><!-- due date --><!--
                                            <Grid Grid.Row="2">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock HorizontalAlignment="Left" Margin="0" Text="Due" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="24" />
