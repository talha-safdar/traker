<UserControl x:Class="Traker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:local="clr-namespace:Traker.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <!--
        
    use staticresource for static styles
    and dyanmicresource for theme changing
    
    -->
    
    <Grid Background="{StaticResource MainBackgroundBrush}" cal:Message.Attach="[Event PreviewMouseDown] = [Action OnMouseDownEvent($source)]">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.235*" /> <!-- side panel -->
            <ColumnDefinition Width="*" /> <!-- main panel -->
        </Grid.ColumnDefinitions>
            
        <!-- side panel -->
        <Grid Grid.Column="0" Margin="20,20,10,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.1*" /> <!-- buttons -->
                <RowDefinition Height="*" /> <!-- information status -->
            </Grid.RowDefinitions>

            <!-- buttons -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <!-- panel container -->
                <Border CornerRadius="15" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="2">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- edit clients -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,20,0">
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action EditClient()]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/user-round.svg" Width="25" Height="25"/>
                            </Border>
                            <Border  Margin="-30,15,0,0">
                                <Border Background="#1E1E1E" CornerRadius="25" Margin="10">
                                    <svg:SvgViewbox                  
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/pen.svg" Width="15" Height="15"/>
                                </Border>
                            </Border>
                        </StackPanel>

                        <!-- edit jobs -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action EditClient()]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/briefcase-business.svg" Width="25" Height="25"/>
                            </Border>
                            <Border  Margin="-30,15,0,0">
                                <Border Background="#1E1E1E" CornerRadius="25" Margin="10">
                                    <svg:SvgViewbox                  
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/pen.svg" Width="15" Height="15"/>
                                </Border>
                            </Border>
                        </StackPanel>

                        <!-- spacer -->
                        <Border Background="#555555" Width="2" Margin="20,10" />

                        <!-- add client -->
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,20,0">
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action EditClient()]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/user-round-plus.svg" Width="25" Height="25"/>
                            </Border>
                        </StackPanel>                            

                        <!-- add job -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                            <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action EditClient()]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/briefcase-business.svg" Width="25" Height="25"/>
                            </Border>
                            <Border  Margin="-30,15,0,0">
                                <Border Background="#1E1E1E" CornerRadius="25" Margin="10">
                                    <svg:SvgViewbox                  
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/plus.svg" Width="9" Height="9"/>
                                </Border>                                
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- infromation status -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <!-- panel container -->
                <Border CornerRadius="15" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0.5*" /> <!-- jobs information -->
                            <RowDefinition Height="0.2*" /> <!-- spacer -->
                            <RowDefinition Height="*" /> <!-- money information -->
                        </Grid.RowDefinitions>

                        <!-- jobs information -->
                        <Grid Grid.Row="0" Margin="20,20,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- new -->
                            <Grid Grid.Column="0" Grid.Row="0">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="New" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding NewJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderBrush="#3D3D3D" BorderThickness="2" />
                                </StackPanel>                                
                            </Grid>
                            
                            <!-- active (in progress) -->
                            <Grid Grid.Column="1" Grid.Row="0">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Active" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding InProgressJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderBrush="#3D3D3D" BorderThickness="2" />
                                </StackPanel>
                            </Grid>

                            <!-- Done (completed) -->
                            <Grid Grid.Column="0" Grid.Row="1">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Done" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding CompletedJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderBrush="#3D3D3D" BorderThickness="2" />
                                </StackPanel>
                            </Grid>                            

                            <!-- invoiced -->
                            <Grid Grid.Column="1" Grid.Row="1">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Invoiced" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding InvoicedJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderBrush="#3D3D3D" BorderThickness="2" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                        
                        <!-- spacer -->
                        <Grid Grid.Row="1">
                            <Border Background="#555555" Height="2" Margin="20,0" />
                        </Grid>
                        
                        <!-- money information -->
                        <Grid Grid.Row="2" Margin="20,0,20,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" /> <!-- gross -->
                                <RowDefinition Height="*" /> <!-- received -->
                                <RowDefinition Height="*" /> <!-- overdue -->
                                <RowDefinition Height="*" /> <!-- outstanding -->
                            </Grid.RowDefinitions>
                            
                            <!-- gross payment -->
                            <Grid Grid.Row="0">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Gross" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding MoneyPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderBrush="#3D3D3D" BorderThickness="2" />
                                </StackPanel>
                            </Grid>
                            
                            <!-- received payment -->
                            <Grid Grid.Row="1">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Received" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding MoneyReceived, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderBrush="#3D3D3D" BorderThickness="2" />
                                </StackPanel>
                            </Grid>              
                            
                            <!-- outstanding payment -->
                            <Grid Grid.Row="2">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Outstanding" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding MoneyToReceive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderBrush="#3D3D3D" BorderThickness="2" />
                                </StackPanel>
                            </Grid>   
                            
                            <!-- overdue payment -->
                            <Grid Grid.Row="3">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Overdue" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <TextBox IsReadOnly="True" Text="{Binding MoneyOverdue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderBrush="#3D3D3D" BorderThickness="2" />
                                </StackPanel>
                            </Grid>     
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <!-- main panel -->
        <Grid Grid.Column="1" Margin="10,20,20,20">
            <!--<Border Background="{StaticResource SidePanelBackgroundBrush}" CornerRadius="20">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5,20,5,10">
                    <Border cal:Message.Attach="[Event MouseLeftButtonUp] = [Action EditClient()]" Background="Transparent"  HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="20" Height="40" Width="40">
                        <svg:SvgViewbox                         
                        RenderOptions.BitmapScalingMode="HighQuality"
                        SnapsToDevicePixels="True"
                        Source="/Resources/Media/Images/Icons/Lucide/user-pen.svg" Width="35" Height="35"/>
                    </Border>
                </StackPanel>
            </Border>-->



            



            <Border Background="{StaticResource TableHeaderBackgroundBrush}" CornerRadius="20">
                <!--SelectionMode= extended // multi row select-->
                <DataGrid 
         x:Name="MainGrid"
                Margin="10"
              RowHeight="40"
              IsReadOnly="True"
              VerticalAlignment="Top"
              HorizontalAlignment="Center"
              SelectionUnit="FullRow"
              BeginningEdit="DataGrid_BeginningEdit"
        cal:Message.Attach="[Event MouseDoubleClick] = [Action EditClient()]"

                ItemsSource="{Binding DashboardData}" 
                SelectedItem="{Binding SelectedDataRow}" 
                AutoGenerateColumns="False" 
                SelectionMode="Single"
                Foreground="{StaticResource FontPrimaryBrush}" 
                FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" 
                FontWeight="Regular" 
                FontSize="22"
                VerticalScrollBarVisibility="Visible"
              HorizontalScrollBarVisibility="Hidden">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="cal:Message.Attach" Value="[Event MouseRightButtonDown] = [Action OpenJobDetails($dataContext)]" />
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding ClientId}" Width="0.1*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Client Name" Binding="{Binding ClientName}" Width="0.5*" >
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Job Description" Binding="{Binding JobDescription}" Width="500">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <!--<DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=£{0:N2}}" Width="0.5*" />-->
                        <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="300" />
                        <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate, StringFormat={}{0:dd/MM/yyyy}}" Width="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="TextAlignment" Value="Left"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>


                        <!-- job status -->
                        <DataGridComboBoxColumn Header="Job Status" SelectedItemBinding="{Binding JobStatus, Mode=TwoWay}" Width="200">
                            <!-- Display mode -->
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.JobStatusEdit, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                    <Setter Property="Focusable" Value="False"/>
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>

                            <!-- Edit mode -->
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.JobStatusEdit, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>


                        <DataGridTemplateColumn  Header="Invoice Status" Width="200">
                            <!-- Display mode -->
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding InvoiceStatus}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                            <!-- Edit mode -->
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.InvoiceStatusEdit,
                            ElementName=MainGrid}"
                          SelectedItem="{Binding InvoiceStatus, Mode=TwoWay}"
                          IsEnabled="{Binding HasInvoice}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>



        </Grid>
            
        <!-- main body -->
