<UserControl x:Class="Traker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:local="clr-namespace:Traker.Views" xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <!--
        
    use staticresource for static styles
    and dyanmicresource for theme changing
    
    -->
    
    <Grid Background="{StaticResource MainBackgroundBrush}" cal:Message.Attach="[Event PreviewMouseDown] = [Action OnMouseDownEvent($source)]">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.235*" /> <!-- side panel -->
            <ColumnDefinition Width="*" /> <!-- main panel -->
        </Grid.ColumnDefinitions>
            
        <!-- side panel -->
        <Grid Grid.Column="0" Margin="20,20,10,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.1*" /> <!-- buttons -->
                <RowDefinition Height="*" /> <!-- information status -->
            </Grid.RowDefinitions>

            <!-- buttons -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <!-- panel container -->
                <Border SnapsToDevicePixels="True" Background="#242424" CornerRadius="20" BorderThickness="1.5">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                            <!-- This whole gradient is now at 50% of its original opacity -->
                            <GradientStop Color="LightGray" Offset="0" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- edit clients -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,20,0">
                            <Border SnapsToDevicePixels="True" BorderThickness="1" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action EditClient()]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- 1. Base Background (rgba 255,255,255, 0.05) -->
                                        <Setter Property="Background" Value="#0DFFFFFF" />

                                        <!-- 2. The 1px Gradient Border -->
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="BorderBrush">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <!-- Top Highlight -->
                                                    <GradientStop Color="#40FFFFFF" Offset="0" />
                                                    <!-- Bottom Fade -->
                                                    <GradientStop Color="#05FFFFFF" Offset="1" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>

                                        <Style.Triggers>
                                            <!-- 3. Hover State -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <!-- Increase opacity to rgba 255,255,255, 0.1 -->
                                                <Setter Property="Background" Value="#1AFFFFFF" />
                                                <Setter Property="Cursor" Value="Hand" />

                                                <!-- 4. Subtle Glow -->
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="10" 
                                                          Color="LightGray" 
                                                          Opacity="0.15" 
                                                          ShadowDepth="0" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/user-round.svg" Width="25" Height="25"/>
                            </Border>
                            <Border  Margin="-30,15,0,0">
                                <Border Background="#1E1E1E" CornerRadius="25" Margin="10">
                                    <svg:SvgViewbox                  
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/pen.svg" Width="15" Height="15"/>
                                </Border>
                            </Border>
                        </StackPanel>

                        <!-- edit jobs -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                            <Border SnapsToDevicePixels="True" BorderThickness="1" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action EditJob('$source')]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- 1. Base Background (rgba 255,255,255, 0.05) -->
                                        <Setter Property="Background" Value="#0DFFFFFF" />

                                        <!-- 2. The 1px Gradient Border -->
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="BorderBrush">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <!-- Top Highlight -->
                                                    <GradientStop Color="#40FFFFFF" Offset="0" />
                                                    <!-- Bottom Fade -->
                                                    <GradientStop Color="#05FFFFFF" Offset="1" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>

                                        <Style.Triggers>
                                            <!-- 3. Hover State -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <!-- Increase opacity to rgba 255,255,255, 0.1 -->
                                                <Setter Property="Background" Value="#1AFFFFFF" />
                                                <Setter Property="Cursor" Value="Hand" />

                                                <!-- 4. Subtle Glow -->
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="10" 
                                                          Color="LightGray" 
                                                          Opacity="0.15" 
                                                          ShadowDepth="0" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/briefcase-business.svg" Width="25" Height="25"/>
                            </Border>
                            <Border  Margin="-30,15,0,0">
                                <Border Background="#1E1E1E" CornerRadius="25" Margin="10">
                                    <svg:SvgViewbox                  
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/pen.svg" Width="15" Height="15"/>
                                </Border>
                            </Border>
                        </StackPanel>

                        <!-- spacer -->
                        <!-- Width="1" for a vertical line; set a specific Height or let it Stretch -->
                        <Border Margin="15,10" Width="1" SnapsToDevicePixels="True">
                            <Border.Background>
                                <!-- StartPoint/EndPoint set to Y-axis (0,0 to 0,1) for vertical fade -->
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="1">
                                    <!-- Top: Transparent -->
                                    <GradientStop Color="#00555555" Offset="0" />
                                    <!-- Solid area moved towards middle -->
                                    <GradientStop Color="#FF555555" Offset="0.3" />
                                    <GradientStop Color="#FF555555" Offset="0.7" />
                                    <!-- Bottom: Transparent -->
                                    <GradientStop Color="#00555555" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- add client -->
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,20,0">
                            <Border SnapsToDevicePixels="True" BorderThickness="1" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action AddClient()]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- 1. Base Background (rgba 255,255,255, 0.05) -->
                                        <Setter Property="Background" Value="#0DFFFFFF" />

                                        <!-- 2. The 1px Gradient Border -->
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="BorderBrush">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <!-- Top Highlight -->
                                                    <GradientStop Color="#40FFFFFF" Offset="0" />
                                                    <!-- Bottom Fade -->
                                                    <GradientStop Color="#05FFFFFF" Offset="1" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>

                                        <Style.Triggers>
                                            <!-- 3. Hover State -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <!-- Increase opacity to rgba 255,255,255, 0.1 -->
                                                <Setter Property="Background" Value="#1AFFFFFF" />
                                                <Setter Property="Cursor" Value="Hand" />

                                                <!-- 4. Subtle Glow -->
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="10" 
                                                          Color="LightGray" 
                                                          Opacity="0.15" 
                                                          ShadowDepth="0" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/user-round-plus.svg" Width="25" Height="25"/>
                            </Border>
                        </StackPanel>                            

                        <!-- add job -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                            <Border SnapsToDevicePixels="True" BorderThickness="1" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action AddJob()]" Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- 1. Base Background (rgba 255,255,255, 0.05) -->
                                        <Setter Property="Background" Value="#0DFFFFFF" />

                                        <!-- 2. The 1px Gradient Border -->
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="BorderBrush">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <!-- Top Highlight -->
                                                    <GradientStop Color="#40FFFFFF" Offset="0" />
                                                    <!-- Bottom Fade -->
                                                    <GradientStop Color="#05FFFFFF" Offset="1" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>

                                        <Style.Triggers>
                                            <!-- 3. Hover State -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <!-- Increase opacity to rgba 255,255,255, 0.1 -->
                                                <Setter Property="Background" Value="#1AFFFFFF" />
                                                <Setter Property="Cursor" Value="Hand" />

                                                <!-- 4. Subtle Glow -->
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="10" 
                                                          Color="LightGray" 
                                                          Opacity="0.15" 
                                                          ShadowDepth="0" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/briefcase-business.svg" Width="25" Height="25"/>
                            </Border>
                            <Border SnapsToDevicePixels="True" Margin="-30,15,0,0">
                                <Border SnapsToDevicePixels="True" Background="#1E1E1E" CornerRadius="25" Margin="10">
                                    <svg:SvgViewbox                  
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/plus.svg" Width="9" Height="9"/>
                                </Border>                                
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- infromation status -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <!-- panel container -->
                <Border Background="#242424" CornerRadius="20" BorderThickness="1.5">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                            <!-- This whole gradient is now at 50% of its original opacity -->
                            <GradientStop Color="LightGray" Offset="0" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" /> <!-- jobs information -->
                            <RowDefinition Height="0.15*" /> <!-- spacer -->
                            <RowDefinition Height="auto" /> <!-- money information -->
                            <RowDefinition Height="0.15*" /> <!-- spacer -->
                            <RowDefinition Height="auto" /> <!-- profile / account -->
                        </Grid.RowDefinitions>

                        <!-- jobs information -->
                        <Grid Grid.Row="0" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- new -->
                            <Grid Grid.Column="0" Grid.Row="0" Margin="10,0,10,20">
                                <Border CornerRadius="10" BorderThickness="1" SnapsToDevicePixels="True">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                            <!-- This whole gradient is now at 50% of its original opacity -->
                                            <GradientStop Color="LightGray" Offset="0" />
                                            <GradientStop Color="Transparent" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <StackPanel Orientation="Vertical" Margin="10">
                                        <TextBlock Foreground="LightCoral" Margin="5,0,0,0" Text="New" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" FontSize="22" />
                                        <TextBlock Margin="5,0,0,0" Text="{Binding NewJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="42" />
                                    </StackPanel>    
                                </Border>
                            </Grid>
                            
                            <!-- active (in progress) -->
                            <Grid Grid.Column="1" Grid.Row="0" Margin="10,0,10,20">
                                <Border CornerRadius="10" BorderThickness="1" SnapsToDevicePixels="True">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                            <!-- This whole gradient is now at 50% of its original opacity -->
                                            <GradientStop Color="LightGray" Offset="0" />
                                            <GradientStop Color="Transparent" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <StackPanel Orientation="Vertical" Margin="10">
                                        <TextBlock Foreground="DarkOrange" Margin="5,0,0,0" Text="Active" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" FontSize="22" />
                                        <TextBlock Margin="5,0,0,0" Text="{Binding ActiveJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="42" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Done (completed) -->
                            <Grid Grid.Column="0" Grid.Row="1" Margin="10,0,10,0">
                                <Border CornerRadius="10" BorderThickness="1" SnapsToDevicePixels="True">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                            <!-- This whole gradient is now at 50% of its original opacity -->
                                            <GradientStop Color="LightGray" Offset="0" />
                                            <GradientStop Color="Transparent" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <StackPanel Orientation="Vertical" Margin="10">
                                        <TextBlock Foreground="LightGreen" Margin="5,0,0,0" Text="Done" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" FontSize="22" />
                                        <TextBlock Margin="5,0,0,0" Text="{Binding DoneJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="42" />
                                    </StackPanel>
                                </Border>
                            </Grid>                            

                            <!-- invoiced -->
                            <Grid Grid.Column="1" Grid.Row="1" Margin="10,0,10,0">
                                <Border CornerRadius="10" BorderThickness="1" SnapsToDevicePixels="True">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                            <!-- This whole gradient is now at 50% of its original opacity -->
                                            <GradientStop Color="LightGray" Offset="0" />
                                            <GradientStop Color="Transparent" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <StackPanel Orientation="Vertical" Margin="10">
                                        <TextBlock Foreground="LightBlue" Margin="5,0,0,0" Text="Invoiced" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" FontSize="22" />
                                        <TextBlock Margin="5,0,0,0" Text="{Binding InvoicedJobsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="{StaticResource FontSecondaryBrush}" FontSize="42" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                        
                        <!-- spacer -->
                        <Grid Grid.Row="1">
                            <Border Margin="30,0" Height="1" SnapsToDevicePixels="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5" Opacity="1">
                                        <!-- Left: Transparent -->
                                        <GradientStop Color="#00555555" Offset="0" />
                                        <!-- Middle: Your #555555 color -->
                                        <GradientStop Color="#FF555555" Offset="0.8" />
                                        <GradientStop Color="#FF555555" Offset="0.2" />
                                        <!-- Right: Transparent -->
                                        <GradientStop Color="#00555555" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                        
                        <!-- money information -->
                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" /> <!-- gross -->
                                <RowDefinition Height="*" /> <!-- received -->
                                <RowDefinition Height="*" /> <!-- overdue -->
                                <RowDefinition Height="*" /> <!-- outstanding -->
                            </Grid.RowDefinitions>
                            
                            <!-- gross payment -->
                            <Grid Grid.Row="0">
                                <StackPanel Orientation="Vertical" Margin="10,10,10,30">
                                    <TextBlock Margin="5,0,0,0" Text="Gross" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <Border CornerRadius="10" BorderThickness="1.5" SnapsToDevicePixels="True">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="LightGray" Opacity="0.25" />
                                        </Border.BorderBrush>
                                        <!--<Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.15">
                                                --><!-- This whole gradient is now at 50% of its original opacity --><!--
                                                <GradientStop Color="LightGray" Offset="1" />
                                                <GradientStop Color="Black" Offset="0" />
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>-->
                                        <TextBox Style="{StaticResource TextBoxReadOnly}" Cursor="Arrow" Foreground="{StaticResource FontSecondaryBrush}" IsReadOnly="True" Text="{Binding GrossAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="32" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderThickness="0" />                                        
                                    </Border>
                                </StackPanel>
                            </Grid>
                            
                            <!-- received payment -->
                            <Grid Grid.Row="1">
                                    <StackPanel Orientation="Vertical" Margin="10,10,10,30">
                                        <TextBlock Margin="5,0,0,0" Text="Received" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <Border CornerRadius="10" BorderThickness="1.5" SnapsToDevicePixels="True">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="LightGray" Opacity="0.25" />
                                        </Border.BorderBrush>
                                        <TextBox Style="{StaticResource TextBoxReadOnly}" Cursor="Arrow" Foreground="{StaticResource FontSecondaryBrush}" IsReadOnly="True" Text="{Binding ReceivedAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="32" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderThickness="0" />
                                    </Border>
                                </StackPanel>
                            </Grid>              
                            
                            <!-- outstanding payment -->
                            <Grid Grid.Row="2">
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Margin="5,0,0,0" Text="Outstanding" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                    <Border CornerRadius="10" BorderThickness="1.5" SnapsToDevicePixels="True">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="LightGray" Opacity="0.25" />
                                        </Border.BorderBrush>
                                        <TextBox Style="{StaticResource TextBoxReadOnly}" Cursor="Arrow" Foreground="{StaticResource FontSecondaryBrush}" IsReadOnly="True" Text="{Binding OutstandingAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="32" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" BorderThickness="0" />
                                    </Border>
                                </StackPanel>
                            </Grid>     
                        </Grid>

                        <!-- spacer -->
                        <Grid Grid.Row="3">
                            <Border Margin="30,0" Height="1" SnapsToDevicePixels="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5" Opacity="1">
                                        <!-- Left: Transparent -->
                                        <GradientStop Color="#00555555" Offset="0" />
                                        <!-- Middle: Your #555555 color -->
                                        <GradientStop Color="#FF555555" Offset="0.8" />
                                        <GradientStop Color="#FF555555" Offset="0.2" />
                                        <!-- Right: Transparent -->
                                        <GradientStop Color="#00555555" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <!-- profile / account -->
                        <Grid Grid.Row="4">
                            <Border SnapsToDevicePixels="True" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action OpenUserContenxtMenu($source)]" Background="#121212" CornerRadius="15" Height="65" Padding="5,0" BorderThickness="1">
                                <Border.Style>
                                    <!--<SolidColorBrush Color="LightGray" Opacity="0.5" />-->
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#121212"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0,0,0">
                                    <Border Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="50" Width="50">
                                        <svg:SvgViewbox                         
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="/Resources/Media/Images/Icons/Lucide/user-round-cog.svg" Width="25" Height="25"/>
                                    </Border>
                                    <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Text="{Binding Data.User[0].FullName}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22" />
                                </StackPanel>                                
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <!-- main panel -->
        <Grid Grid.Column="1" Margin="10,10,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.04*" /> <!-- search / filter / sort -->
                <RowDefinition Height="*" /> <!-- job cards -->
            </Grid.RowDefinitions>

            <!-- search / filter / sort -->
            <Grid Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" /> <!-- total jobs (to become search bar) -->
                        <ColumnDefinition Width="*" /> <!-- line spacer -->
                        <ColumnDefinition Width="auto" /> <!-- filter/sort -->
                    </Grid.ColumnDefinitions>

                    <!-- total jobs (to become search bar) -->
                    <Grid Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Margin="5,0,0,0" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontSecondaryBrush}" FontSize="22">
                            <Run Text="Total Jobs: " />
                            <Run Text="{Binding TotalJobsCount}" />
                        </TextBlock>
                    </Grid>

                    <!-- line spacer -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Border Margin="30,0" Height="1" SnapsToDevicePixels="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5" Opacity="1">                                    <!-- Left: Transparent -->
                                    <GradientStop Color="#00555555" Offset="0" />                                    <!-- Middle: Your #555555 color -->
                                    <GradientStop Color="#FF555555" Offset="0.5" />                                    <!-- Right: Transparent -->
                                    <GradientStop Color="#00555555" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <!-- filter/sort -->
                    <Grid Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,5,0">
                            <Border Cursor="Hand" Margin="0,0,10,0" Opacity="0.8" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action OpenFilterContextMenu($source)]" Background="{StaticResource SidePanelBackgroundBrush}" BorderBrush="{StaticResource FontPrimaryBrush}" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="35" Width="35">
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/list-filter.svg" Width="15" Height="15"/>
                            </Border>
                            <Border Cursor="Hand" Opacity="0.8" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action OpenSortContextMenu($source)]" Background="{StaticResource SidePanelBackgroundBrush}" BorderBrush="{StaticResource FontPrimaryBrush}" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="35" Width="35">
                                <svg:SvgViewbox                         
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    SnapsToDevicePixels="True"
                                    Source="/Resources/Media/Images/Icons/Lucide/arrow-up-down.svg" Width="15" Height="15"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
                

            </Grid>

            <!-- job cards -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Border Background="#242424" CornerRadius="20" BorderThickness="1.5" SnapsToDevicePixels="True">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                            <!-- This whole gradient is now at 50% of its original opacity -->
                            <GradientStop Color="LightGray" Offset="0" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10,20,10,10" Padding="0,0,10,0">
                        <ItemsControl ItemsSource="{Binding DashboardData}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border 
                                        Background="#242424"
                            BorderThickness="1"
                            Height="135"
                            CornerRadius="20" 
                            Margin="20,10,20,10" 
                            Padding="10"
                            cal:Message.Attach="[Event MouseLeftButtonUp] = [Action SelectJob($dataContext)];
                                                [Event MouseRightButtonUp] = [Action OpenContextMenu($dataContext)];"
                                Cursor="Hand"
                            MouseLeftButtonDown="EditJob">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <!-- 1. Default BorderBrush -->
                                                <Setter Property="BorderBrush" Value="#121212"/>

                                                <!-- 2. Default Shadow (Moved from local to Style) -->
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="Black" 
                                                          BlurRadius="15" 
                                                          ShadowDepth="0" 
                                                          Opacity="0.3" 
                                                          RenderingBias="Quality"/>
                                                    </Setter.Value>
                                                </Setter>

                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#80404040"/>

                                                        <!-- 3. Increased Blur Shadow on Hover -->
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="Black" 
                                                              BlurRadius="30" 
                                                              ShadowDepth="0" 
                                                              Opacity="0.8" 
                                                              RenderingBias="Quality"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid IsHitTestVisible="False">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.3*" />                                                <!-- type -->
                                                <ColumnDefinition Width="*" />                                                <!-- full name / job title -->
                                                <ColumnDefinition Width="0.2*" />                                                <!-- spacer -->
                                                <ColumnDefinition Width="0.5*" />                                                <!-- job status / due date -->
                                                <ColumnDefinition Width="0.2*" />                                                <!-- spacer -->
                                                <ColumnDefinition Width="*" />                                                <!-- job price -->
                                            </Grid.ColumnDefinitions>

                                            <!-- type -->
                                            <Grid Grid.Column="0">
                                                <Border Background="#1E1E1E"  HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="40" Height="80" Width="80">
                                                    <svg:SvgViewbox                         
                                                        RenderOptions.BitmapScalingMode="HighQuality"
                                                        SnapsToDevicePixels="True"
                                                        Source="{Binding TypeIcon}" Width="40" Height="40"/>
                                                </Border>
                                            </Grid>

                                            <!-- full name / job title -->
                                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />                                                    <!-- full name -->
                                                    <RowDefinition Height="*" />                                                    <!-- spacer -->
                                                    <RowDefinition Height="*" />                                                    <!-- job title -->
                                                </Grid.RowDefinitions>

                                                <!-- full name -->
                                                <Grid Grid.Row="0">
                                                    <TextBlock Margin="5,0,0,0" Text="{Binding ClientName}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Black" Foreground="{StaticResource FontPrimaryBrush}" FontSize="32" />
                                                </Grid>

                                                <!-- spacer -->
                                                <Grid Grid.Row="1" Margin="0,10" />

                                                <!-- job title -->
                                                <Grid Grid.Row="2">
                                                    <TextBlock Margin="5,0,0,0" Opacity="0.8" Text="{Binding JobTitle}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="24" />
                                                </Grid>
                                            </Grid>

                                            <!-- spacer-->
                                            <Grid Grid.Column="2">
                                                <!--<Border Margin="0,0" Width="1" SnapsToDevicePixels="True" Opacity="0.6">
                                                    <Border.Background>
                                                        --><!-- Changed StartPoint/EndPoint to move vertically (Top to Bottom) --><!--
                                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="1">
                                                            --><!-- Top: Transparent --><!--
                                                            <GradientStop Color="#00555555" Offset="0" />
                                                            --><!-- Middle: Your #555555 color --><!--
                                                            <GradientStop Color="#FF555555" Offset="0.2" />
                                                            <GradientStop Color="#FF555555" Offset="0.8" />
                                                            --><!-- Bottom: Transparent --><!--
                                                            <GradientStop Color="#00555555" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>-->
                                            </Grid>

                                            <!-- job status / due date -->
                                            <Grid Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />                                                    <!-- job status -->
                                                    <RowDefinition Height="0.5*" />                                                    <!-- spacer -->
                                                    <RowDefinition Height="*" />                                                    <!-- due date -->
                                                </Grid.RowDefinitions>

                                                <!-- job status -->
                                                <Grid Grid.Row="0">
                                                    <TextBlock Margin="0" Text="{Binding JobStatus}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Black" FontSize="32">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource FontPrimaryBrush}" />

                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding JobStatus}" Value="New">
                                                                        <Setter Property="Foreground" Value="LightCoral" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding JobStatus}" Value="Active">
                                                                        <Setter Property="Foreground" Value="DarkOrange" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding JobStatus}" Value="Done">
                                                                        <Setter Property="Foreground" Value="LightGreen" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding JobStatus}" Value="Invoiced">
                                                                        <Setter Property="Foreground" Value="LightBlue" />
                                                                        <Setter Property="FontWeight" Value="Bold" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>

                                                <!-- spacer -->
                                                <Grid Grid.Row="1" Margin="0,10" />

                                                <!-- due date -->
                                                <Grid Grid.Row="2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock HorizontalAlignment="Left" Margin="0" Text="Due" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Bold" Foreground="#888888" FontSize="24" />
                                                        <TextBlock Margin="10,0,0,0" Text="{Binding DueDate}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="{StaticResource FontPrimaryBrush}" FontSize="24" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>

                                            <!-- spacer -->
                                            <Grid Grid.Column="4">
                                                <!--<Border Margin="0,0" Width="1" SnapsToDevicePixels="True" Opacity="0.6">
                                                    <Border.Background>
                                                        --><!-- Changed StartPoint/EndPoint to move vertically (Top to Bottom) --><!--
                                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="1">
                                                            --><!-- Top: Transparent --><!--
                                                            <GradientStop Color="#00555555" Offset="0" />
                                                            --><!-- Middle: Your #555555 color --><!--
                                                            <GradientStop Color="#FF555555" Offset="0.2" />
                                                            <GradientStop Color="#FF555555" Offset="0.8" />
                                                            --><!-- Bottom: Transparent --><!--
                                                            <GradientStop Color="#00555555" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>-->
                                            </Grid>

                                            <!-- job price -->
                                            <Grid Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Margin="0" Text="{Binding Price}" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" FontWeight="SemiBold" Foreground="{StaticResource FontPrimaryBrush}" FontSize="32" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
