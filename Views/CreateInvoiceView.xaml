<UserControl x:Class="Traker.Views.CreateInvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:behaviours="clr-namespace:Traker.Behaviours"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:conv="clr-namespace:Traker.Converters"
             xmlns:local="clr-namespace:Traker.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Height="800" Width="1000"
                          Focusable="True"
             cal:Message.Attach="[Event PreviewKeyDown] = [Action HandleKeyPress($eventArgs)]">

    <Border Margin="5" Height="800" Width="1000" Background="#1E1E1E" CornerRadius="20" BorderThickness="1" SnapsToDevicePixels="True">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                <GradientStop Color="LightGray" Offset="0" />
                <GradientStop Color="Transparent" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="0"/>
        </Border.Effect>

        <Grid Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.1*" />                <!-- top bar        -->
                <RowDefinition Height="auto" />                <!-- main contents       -->
                <RowDefinition Height="0.15*" />                <!-- buttons        -->
            </Grid.RowDefinitions>

            <!-- top bar -->
            <Grid Grid.Row="0">
                <!-- close -->
                <Border Cursor="Hand" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action Exit()]" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="20" Height="35" Width="35">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#404040"/>
                            <Setter Property="Opacity" Value="0.5"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <svg:SvgViewbox RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Resources/Media/Images/Icons/Lucide/x.svg" Width="15" Height="15"/>
                </Border>
            </Grid>

            <!-- main contents -->
            <Grid Grid.Row="1" VerticalAlignment="Center" Margin="80,0,80,0">
                <Border Background="#242424" CornerRadius="15" BorderThickness="1.5" Margin="40,20" SnapsToDevicePixels="True">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="LightGray" Opacity="0.25" />
                    </Border.BorderBrush>

                    <Grid Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" /> <!-- client info -->
                            <RowDefinition Height="*" /> <!-- money info -->
                        </Grid.RowDefinitions>

                        <!-- client info -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- billing name -->
                            <Grid Grid.Column="0" Grid.Row="0" Margin="0,0,5,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Billing Name" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding BillingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans"
                                        behaviours:TextboxFilter.EnableFilter="True"
                                        behaviours:TextboxFilter.FilterMode="LettersAndSpacesOnly" />
                                </StackPanel>
                            </Grid>

                            <!-- billing city -->
                            <Grid Grid.Column="1" Grid.Row="0" Margin="5,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Billing City" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding BillingCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans"
                                        behaviours:TextboxFilter.EnableFilter="True"
                                        behaviours:TextboxFilter.FilterMode="LettersAndSpacesOnly" />
                                </StackPanel>
                            </Grid>

                            <!-- billing address -->
                            <Grid Grid.Column="0" Grid.Row="1" Grid.RowSpan="2" Margin="0,0,5,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Billing Address" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Height="153" Style="{DynamicResource TextBoxNormal}" Text="{Binding BillingAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="100" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans"
                                        behaviours:TextboxFilter.EnableFilter="True"
                                        behaviours:TextboxFilter.FilterMode="AlphaNumericWithSpaces" />
                                </StackPanel>
                            </Grid>

                            <!-- billing country -->
                            <Grid Grid.Column="1" Grid.Row="1" Grid.RowSpan="1" Margin="5,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Billing Country" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding BillingCountry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans"
                                        behaviours:TextboxFilter.EnableFilter="True"
                                        behaviours:TextboxFilter.FilterMode="LettersAndSpacesOnly" />
                                </StackPanel>
                            </Grid>

                            <!-- billing postcode -->
                            <Grid Grid.Column="1" Grid.Row="2" Grid.RowSpan="1" Margin="5,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Billing Postcode" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding BillingPostcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans"
                                        behaviours:TextboxFilter.EnableFilter="True"
                                        behaviours:TextboxFilter.FilterMode="AlphaNumericWithSpaces" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- money info -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <!-- due date -->
                            <Grid Grid.Column="0" Grid.Row="0" Margin="0,0,5,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Due Date" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Style="{DynamicResource TextBoxNormal}" Text="{Binding DueDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="10" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans"
                                        behaviours:TextboxFilter.EnableFilter="True"
                                        behaviours:TextboxFilter.FilterMode="DateDDMMYYYY" />
                                </StackPanel>
                            </Grid>
                            
                            <!-- subtotal -->
                            <Grid Grid.Column="1" Grid.Row="0" Margin="5,0,5,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" Text="Subtotal" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22"/>
                                    <TextBox Opacity="0.6" IsHitTestVisible="False" Focusable="False" Style="{DynamicResource TextBoxNormal}" Text="{Binding Subtotal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="35" AcceptsReturn="False" TextWrapping="Wrap" Padding="10" FontSize="22" FontFamily="pack://Traker:,,,/Resources/Fonts/#Public Sans" />
                                </StackPanel>
                            </Grid>
                            
                            <!-- vat -->
                            <Grid Grid.Column="2" Grid.Row="0" Margin="5,0,0,25">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock VerticalAlignment="Center" Margin="5,0,0,5" Text="VAT" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22" />
                                    <ComboBox Style="{DynamicResource ComboBoxNormal}" ItemsSource="{Binding InvoiceStatusEdit}" SelectedItem="{Binding VatValue, Mode=TwoWay}" SelectedValuePath="Content" FontSize="22" />
                                </StackPanel>
                            </Grid>
                            
                            <!-- total -->
                            <Grid Grid.ColumnSpan="3" Grid.Row="1" HorizontalAlignment="Center">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Margin="5,0,0,5" FontFamily="pack://Traker:,,,/Resources/Fonts/#Montserrat" FontWeight="Regular" Foreground="#888888" FontSize="22">
                                        <Run Text="Total: " />
                                        <Run Text="{Binding TotalAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:C2}}" FontSize="38" FontWeight="SemiBold" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- butons -->
            <Grid Grid.Row="2">
                <!-- submit -->
                <Grid Grid.Column="2">
                    <Border Cursor="Hand" x:Name="SubmitBorder" MouseLeave="SubmitBorder_MouseLeave" MouseLeftButtonUp="SubmitBorder_MouseLeftButtonUp" MouseLeftButtonDown="SubmitBorder_MouseLeftButtonDown" IsEnabled="{Binding EnableSubmitBtn}" Opacity="{Binding OpacitySubmitBtn}" SnapsToDevicePixels="True" cal:Message.Attach="[Event MouseLeftButtonUp] = [Action CreateInvoice()]" Background="#333333" CornerRadius="23" Height="45" Width="200" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <!-- DEFAULT STATE -->
                                <Setter Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1" Opacity="0.25">
                                            <GradientStop Color="LightGray" Offset="0" />
                                            <GradientStop Color="Transparent" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>

                                <!-- HOVER STATE -->
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#80D3D3D3"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock conv:TextBlockSpacer.LetterSpacing="2.01" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Create Invoice" FontFamily="pack://Traker:,,,/Resources/Fonts/#Inter" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="18" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>